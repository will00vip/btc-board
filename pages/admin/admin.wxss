/* pages/admin/admin.wxss */
page { background: #090b10; }

.admin-page {
  min-height: 100vh;
  background: #090b10;
  padding: 0 0 60rpx;
}

/* ══ 密码锁屏 ══ */
.lock-screen {
  min-height: 100vh;
  display: flex; align-items: center; justify-content: center;
  padding: 0 60rpx;
}
.lock-box {
  width: 100%;
  background: linear-gradient(160deg, #0d1a2e, #090d18);
  border: 1.5rpx solid rgba(251,191,36,.25);
  border-radius: 40rpx;
  padding: 60rpx 44rpx;
  text-align: center;
}
.lock-icon  { display: block; font-size: 80rpx; margin-bottom: 20rpx; }
.lock-title {
  display: block; font-size: 40rpx; font-weight: 900;
  background: linear-gradient(135deg,#fbbf24,#fb923c);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  background-clip: text; margin-bottom: 40rpx;
}
.lock-input {
  width: 100%; height: 88rpx;
  background: rgba(255,255,255,.06);
  border: 1.5rpx solid rgba(255,255,255,.12);
  border-radius: 20rpx;
  padding: 0 28rpx; font-size: 32rpx; color: #f1f5f9;
  text-align: center; letter-spacing: 8rpx;
  margin-bottom: 28rpx;
}
.lock-placeholder { color: rgba(255,255,255,.25); letter-spacing: 2rpx; }
.lock-btn {
  background: rgba(255,255,255,.08);
  border-radius: 60rpx; padding: 24rpx 0;
  font-size: 30rpx; color: rgba(255,255,255,.3); font-weight: 900;
}
.lock-btn.active {
  background: linear-gradient(135deg,#d97706,#fbbf24);
  color: #0d1117;
  box-shadow: 0 6rpx 24rpx rgba(251,191,36,.3);
}
.lock-err { display: block; margin-top: 20rpx; font-size: 24rpx; color: #ef5350; }

/* ══ 后台主界面 ══ */
.admin-header {
  padding: 60rpx 36rpx 30rpx;
  border-bottom: 1rpx solid rgba(255,255,255,.08);
}
.admin-title {
  display: block; font-size: 40rpx; font-weight: 900; color: #fbbf24; margin-bottom: 8rpx;
}
.admin-sub { display: block; font-size: 24rpx; color: rgba(255,255,255,.35); }

/* ══ 卡片通用 ══ */
.gen-card, .issued-card {
  margin: 28rpx 24rpx 0;
  background: linear-gradient(160deg,#0d1a2e,#090d18);
  border: 1.5rpx solid rgba(255,255,255,.1);
  border-radius: 32rpx;
  padding: 36rpx 32rpx;
}
.card-title { display: block; font-size: 30rpx; font-weight: 900; color: #f1f5f9; margin-bottom: 28rpx; }

/* ══ 类型选择 ══ */
.type-row { display: flex; gap: 16rpx; margin-bottom: 32rpx; }
.type-btn {
  flex: 1; text-align: center; padding: 20rpx 0;
  background: rgba(255,255,255,.05);
  border: 1.5rpx solid rgba(255,255,255,.1);
  border-radius: 20rpx;
  font-size: 26rpx; color: rgba(255,255,255,.45); font-weight: 700;
  transition: all .2s;
}
.type-btn.active.month   { background: rgba(96,165,250,.15); border-color: #60a5fa; color: #60a5fa; }
.type-btn.active.quarter { background: rgba(251,191,36,.15); border-color: #fbbf24; color: #fbbf24; }
.type-btn.active.year     { background: rgba(52,211,153,.15); border-color: #34d399; color: #34d399; }
.type-btn.active.lifetime { background: rgba(167,139,250,.2); border-color: #a78bfa; color: #a78bfa; }

/* ══ 生成按钮 ══ */
.gen-btn {
  background: linear-gradient(135deg,#d97706,#fbbf24);
  border-radius: 60rpx; padding: 28rpx 0; text-align: center;
  box-shadow: 0 8rpx 30rpx rgba(251,191,36,.35);
  margin-bottom: 28rpx;
}
.gen-btn-text { font-size: 32rpx; font-weight: 900; color: #0d1117; letter-spacing: 2rpx; }

/* ══ 生成结果 ══ */
.result-box {
  background: rgba(251,191,36,.08);
  border: 1.5rpx solid rgba(251,191,36,.3);
  border-radius: 20rpx; padding: 24rpx 24rpx;
}
.result-code-row { display: flex; align-items: center; gap: 16rpx; margin-bottom: 12rpx; }
.result-code { flex: 1; font-size: 30rpx; font-weight: 900; color: #fbbf24; letter-spacing: 3rpx; }
.result-meta { display: block; font-size: 22rpx; color: rgba(255,255,255,.4); }

/* ══ 复制按钮 ══ */
.copy-btn {
  background: linear-gradient(135deg,#d97706,#fbbf24);
  color: #0d1117; font-size: 24rpx; font-weight: 900;
  padding: 10rpx 28rpx; border-radius: 16rpx; flex-shrink: 0;
}
.copy-btn.sm { padding: 8rpx 20rpx; font-size: 22rpx; }

/* ══ 已发出列表 ══ */
.issued-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24rpx; }
.issued-count { font-size: 24rpx; color: rgba(255,255,255,.3); }
.issued-empty { text-align: center; font-size: 26rpx; color: rgba(255,255,255,.2); padding: 40rpx 0; }

.issued-item {
  display: flex; align-items: center; justify-content: space-between;
  padding: 20rpx 0; border-bottom: 1rpx solid rgba(255,255,255,.06);
}
.issued-item:last-child { border-bottom: none; }
.issued-left { flex: 1; }
.issued-code { display: block; font-size: 26rpx; font-weight: 800; color: #f1f5f9; margin-bottom: 6rpx; letter-spacing: 1rpx; }
.issued-info { display: block; font-size: 20rpx; color: rgba(255,255,255,.3); }
.issued-right { display: flex; align-items: center; gap: 14rpx; flex-shrink: 0; }
.issued-status { font-size: 22rpx; font-weight: 800; }
.issued-status.fresh { color: #34d399; }
.issued-status.used  { color: rgba(255,255,255,.25); }
.issued-item.used .issued-code { color: rgba(255,255,255,.35); text-decoration: line-through; }

/* ══ 底部统计 ══ */
.stat-row {
  margin: 28rpx 24rpx 0;
  display: flex; gap: 16rpx;
}
.stat-item {
  flex: 1; text-align: center; padding: 28rpx 0;
  background: rgba(255,255,255,.04);
  border: 1rpx solid rgba(255,255,255,.08);
  border-radius: 24rpx;
}
.stat-num  { display: block; font-size: 48rpx; font-weight: 900; color: #f1f5f9; line-height: 1; margin-bottom: 8rpx; }
.stat-num.sold { color: #60a5fa; }
.stat-num.gold { color: #fbbf24; font-size: 36rpx; }
.stat-label { display: block; font-size: 22rpx; color: rgba(255,255,255,.35); }
