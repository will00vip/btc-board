/* pages/index/index.wxss  v9.1  蓝黑深空版 */
/* 主题色：深蓝#3b82f6 / 青色#06b6d4 / 淡紫蓝#818cf8 / 薄荷#10b981 / 金#fbbf24 */

/* ─────────── 全局基础 ─────────── */
page {
  background: #07090f;
  color: #e4ecf7;
  font-size: 28rpx;
  font-family: -apple-system, 'PingFang SC', 'Helvetica Neue', sans-serif;
  -webkit-font-smoothing: antialiased;
}

/* ─────────── 合并顶部导航栏（原ai-banner + navbar合一） ─────────── */
.top-header {
  background: linear-gradient(180deg, #0a1628 0%, #080d1a 100%);
  border-bottom: 1rpx solid rgba(59,130,246,.2);
  padding: 20rpx 24rpx 16rpx;
}
.top-header-inner {
  display: flex; align-items: center; gap: 16rpx;
}
.top-frog-wrap {
  width: 68rpx; height: 68rpx; border-radius: 18rpx; flex-shrink: 0;
  background: linear-gradient(135deg, #1e3a5f, #0e2a4a);
  border: 1.5rpx solid rgba(59,130,246,.4);
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 0 18px rgba(59,130,246,.3);
}
.top-frog-emoji { font-size: 38rpx; line-height: 1; }
.top-title-block { flex: 1; }
.top-title-main {
  display: block; font-size: 30rpx; font-weight: 900;
  background: linear-gradient(90deg, #60a5fa, #06b6d4);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  letter-spacing: 1rpx;
}
.top-title-sub {
  display: block; font-size: 19rpx; color: rgba(96,165,250,.6); margin-top: 3rpx;
}
.top-right-area { display: flex; align-items: center; gap: 14rpx; }
.live-dot {
  width: 12rpx; height: 12rpx; border-radius: 50%; background: #10b981;
  box-shadow: 0 0 8px #10b981; animation: pulse-dot 2s infinite;
}
@keyframes pulse-dot { 0%,100%{box-shadow:0 0 6px #10b981} 50%{box-shadow:0 0 14px #10b981,0 0 20px rgba(16,185,129,.4)} }
.live-dot.loading { background: #fbbf24; box-shadow: 0 0 8px #fbbf24; animation: blink .7s infinite; }
@keyframes blink { 0%,100%{opacity:1} 50%{opacity:.2} }
.nav-refresh-btn {
  background: rgba(59,130,246,.1); border: 1rpx solid rgba(59,130,246,.3);
  padding: 8rpx 22rpx; border-radius: 20rpx; font-size: 26rpx; color: #60a5fa;
  font-weight: 700;
}
.top-vip-btn {
  width: 48rpx; height: 48rpx; border-radius: 50%;
  background: rgba(251,191,36,.12); border: 1.5rpx solid rgba(251,191,36,.35);
  display: flex; align-items: center; justify-content: center; font-size: 26rpx;
}
/* 兼容旧 ai-banner 类（隐藏） */
.ai-banner { display: none; }
/* 兼容旧 navbar（隐藏） */
.navbar { display: none; }

/* ─────────── 60秒倒计时条 ─────────── */
.trial-bar {
  position: relative; height: 60rpx; overflow: hidden;
  background: #090e1a;
}
.trial-bar-fill {
  position: absolute; left: 0; top: 0; bottom: 0;
  background: linear-gradient(90deg, #1d4ed8 0%, #0891b2 50%, #3b82f6 100%);
  transition: width 1s linear;
  opacity: .55;
}
.trial-bar-content {
  position: relative; z-index: 1;
  display: flex; align-items: center; justify-content: center;
  height: 100%; gap: 12rpx;
}
.trial-icon { font-size: 24rpx; }
.trial-txt { font-size: 24rpx; color: #93c5fd; font-weight: 600; }
.trial-secs { color: #fff; font-weight: 900; font-size: 28rpx; }
.trial-secs.urgent { color: #f87171; animation: pulse-red 0.5s infinite alternate; }
@keyframes pulse-red { from { opacity:.6 } to { opacity:1 } }
.trial-cta {
  font-size: 22rpx; color: #fbbf24; font-weight: 700;
  background: rgba(251,191,36,.15); border-radius: 20rpx; padding: 4rpx 14rpx;
}

/* ─────────── 导航栏（兼容旧代码，已隐藏） ─────────── */
.navbar { display: none; }
.navbar-left { display: none; }
.navbar-right { display: none; }
.nav-icon { display: none; }
.nav-title { display: none; }
.nav-sub { display: none; }

/* ─────────── AI评分顶部栏 ─────────── */
.ai-score-top-bar {
  display: flex; align-items: center; gap: 24rpx;
  padding: 16rpx 24rpx 12rpx;
  background: linear-gradient(135deg, rgba(10,14,28,.95) 0%, rgba(15,20,40,.9) 100%);
  border-bottom: 1rpx solid rgba(59,130,246,.15);
}
.ai-score-top-info {
  flex: 1; display: flex; flex-direction: column; gap: 6rpx;
}
.ai-score-top-label {
  font-size: 32rpx; font-weight: 900; color: #64748b;
}
.ai-score-top-label.buy, .ai-score-top-label.signal-long { color: #f87171; }
.ai-score-top-label.short_s, .ai-score-top-label.signal-short { color: #34d399; }
.ai-score-top-label.ok { color: #60a5fa; }
.ai-score-top-label.watch { color: #fbbf24; }
.ai-score-top-label.wait, .ai-score-top-label.no { color: #475569; }
.ai-score-top-hint {
  font-size: 22rpx; color: #475569;
}
.ai-score-signal-dir {
  font-size: 26rpx; font-weight: 800;
  color: #60a5fa;
  letter-spacing: 1rpx;
}
.ai-score-bar-wrap {
  height: 8rpx; background: rgba(255,255,255,.08); border-radius: 8rpx; overflow: hidden; width: 100%;
}
.ai-score-bar-fill {
  height: 100%; border-radius: 8rpx;
  background: linear-gradient(90deg, #3b82f6, #06b6d4);
  transition: width .5s cubic-bezier(.34,1.56,.64,1);
}
.ai-score-bar-fill.buy, .ai-score-bar-fill.signal-long {
  background: linear-gradient(90deg, #f87171, #fb923c);
}
.ai-score-bar-fill.short_s, .ai-score-bar-fill.signal-short {
  background: linear-gradient(90deg, #34d399, #06b6d4);
}
.ai-score-bar-fill.ok { background: linear-gradient(90deg, #60a5fa, #818cf8); }
.ai-score-bar-fill.watch { background: linear-gradient(90deg, #fbbf24, #f59e0b); }

/* ─────────── 价格大头（最顶部紧凑横排） ─────────── */
.price-hero {
  display: flex; flex-direction: row; align-items: center; gap: 16rpx;
  padding: 14rpx 24rpx 10rpx;
  background: linear-gradient(180deg, rgba(8,13,26,.9) 0%, rgba(8,13,26,.5) 100%);
  flex-wrap: wrap;
}
.price-hero-left { display: flex; align-items: center; flex-shrink: 0; }
.price-hero-right { display: flex; flex-direction: column; gap: 8rpx; flex: 1; }
.price-main { font-size: 52rpx; font-weight: 900; letter-spacing: 1rpx; color: #e4ecf7; flex-shrink: 0; }

.price-main.up   { color: #f87171; }
.price-main.down { color: #34d399; }



.price-badges { display: flex; gap: 8rpx; flex-wrap: wrap; }
.price-badge {
  font-size: 20rpx; padding: 4rpx 12rpx; border-radius: 12rpx; font-weight: 700;
}
.price-badge.up   { background: rgba(248,113,113,.18); color: #f87171; }
.price-badge.down { background: rgba(52,211,153,.18);  color: #34d399; }
.price-badge-plain {
  font-size: 20rpx; padding: 4rpx 12rpx; border-radius: 12rpx;
  background: rgba(255,255,255,.06); color: #94a3b8;
}

/* AI评分环（右上角，小版，保留兼容） */
.ai-score-ring {
  display: flex; flex-direction: column; align-items: center;
  width: 100rpx; height: 100rpx; border-radius: 50%;
  background: conic-gradient(#3b82f6 0%, #06b6d4 60%, rgba(255,255,255,.06) 60%);
  justify-content: center;
  box-shadow: 0 0 20px rgba(59,130,246,.4);
  position: relative;
}
.ai-score-ring::before {
  content: ''; position: absolute; width: 76rpx; height: 76rpx;
  border-radius: 50%; background: #07090f;
}
.ai-ring-num {
  position: relative; z-index: 1; font-size: 34rpx; font-weight: 900;
  color: #93c5fd; line-height: 1;
}
.ai-ring-den {
  position: relative; z-index: 1; font-size: 14rpx; color: #64748b; margin-top: -2rpx;
}
.ai-ring-label {
  position: relative; z-index: 1; font-size: 16rpx; color: #3b82f6; font-weight: 700; margin-top: 2rpx;
}

/* AI评分环（大版，price-hero左侧主显示） */
.ai-score-ring-big {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  width: 130rpx; height: 130rpx; border-radius: 50%;
  background: conic-gradient(#3b82f6 0%, #06b6d4 60%, rgba(255,255,255,.06) 60%);
  box-shadow: 0 0 28px rgba(59,130,246,.5);
  position: relative;
}
.ai-score-ring-big::before {
  content: ''; position: absolute; width: 100rpx; height: 100rpx;
  border-radius: 50%; background: #07090f;
}
/* 有信号时颜色变化 */
.ai-score-ring-big.signal-long {
  background: conic-gradient(#f87171 0%, #fb923c 70%, rgba(255,255,255,.06) 70%);
  box-shadow: 0 0 28px rgba(248,113,113,.5);
}
.ai-score-ring-big.signal-short {
  background: conic-gradient(#34d399 0%, #06b6d4 70%, rgba(255,255,255,.06) 70%);
  box-shadow: 0 0 28px rgba(52,211,153,.5);
}
.ai-ring-num-big {
  position: relative; z-index: 1; font-size: 46rpx; font-weight: 900;
  color: #93c5fd; line-height: 1;
}
.ai-ring-den-big {
  position: relative; z-index: 1; font-size: 18rpx; color: #64748b; margin-top: -2rpx;
}
.ai-ring-label-big {
  position: relative; z-index: 1; font-size: 20rpx; color: #3b82f6; font-weight: 700; margin-top: 3rpx;
}



/* ─────────── 周期切换（顶部大行，内嵌K线图顶部旧样式保留兼容） ─────────── */
.period-bar-top {
  display: flex; white-space: nowrap;
  width: 100%; padding: 8rpx 18rpx 10rpx;
  background: rgba(7,9,15,.6);
  border-bottom: 1rpx solid rgba(255,255,255,.06);
}
.period-btn-top {
  display: inline-block; flex-shrink: 0;
  background: rgba(255,255,255,.05); border: 1.5rpx solid rgba(255,255,255,.1);
  border-radius: 16rpx; padding: 8rpx 22rpx;
  font-size: 26rpx; font-weight: 700; color: #64748b;
  margin-right: 10rpx;
  transition: all .2s cubic-bezier(.34,1.56,.64,1);
}
.period-btn-top.active {
  background: linear-gradient(135deg, rgba(59,130,246,.3), rgba(6,182,212,.22));
  border-color: #3b82f6; color: #fff; font-weight: 900;
  box-shadow: 0 0 14px rgba(59,130,246,.4);
  transform: scale(1.07);
}
.period-more-top {
  display: inline-block; flex-shrink: 0;
  background: rgba(251,191,36,.07); border: 1.5rpx solid rgba(251,191,36,.2);
  border-radius: 16rpx; padding: 8rpx 18rpx;
  font-size: 22rpx; color: #fbbf24; font-weight: 700;
}
/* 旧inline样式保留（kline-header内，现在kline-header已不含周期切换，可能不再用） */
.period-bar-inline {
  display: flex; white-space: nowrap;
  width: 100%; margin-top: 10rpx;
}
.period-btn-inline {
  display: inline-block; flex-shrink: 0;
  background: rgba(255,255,255,.04); border: 1.5rpx solid rgba(255,255,255,.08);
  border-radius: 16rpx; padding: 7rpx 22rpx;
  font-size: 26rpx; font-weight: 700; color: #64748b;
  margin-right: 8rpx;
  transition: all .2s cubic-bezier(.34,1.56,.64,1);
}
.period-btn-inline.active {
  background: linear-gradient(135deg, rgba(59,130,246,.28), rgba(6,182,212,.2));
  border-color: #3b82f6; color: #fff; font-weight: 900;
  box-shadow: 0 0 12px rgba(59,130,246,.35);
  transform: scale(1.06);
}
.period-more-inline {
  display: inline-block; flex-shrink: 0;
  background: rgba(251,191,36,.07); border: 1.5rpx solid rgba(251,191,36,.2);
  border-radius: 16rpx; padding: 7rpx 18rpx;
  font-size: 22rpx; color: #fbbf24; font-weight: 700;
}

/* ─────────── 青蛙趋势判断卡 ─────────── */
.frog-trend-card {
  margin: 12rpx 18rpx 0;
  background: rgba(10,16,28,.85);
  border: 1.5rpx solid rgba(59,130,246,.2);
  border-radius: 22rpx 22rpx 0 0;
  padding: 16rpx 20rpx;
  display: flex; align-items: center; justify-content: space-between;
  backdrop-filter: blur(8px);
}
.ftc-left { display: flex; align-items: center; gap: 14rpx; }
.ftc-frog {
  font-size: 42rpx; width: 60rpx; height: 60rpx;
  display: flex; align-items: center; justify-content: center;
  background: linear-gradient(135deg, #0f2744, #0a1e3a);
  border: 1.5rpx solid rgba(59,130,246,.35);
  border-radius: 16rpx;
  box-shadow: 0 0 14px rgba(59,130,246,.25);
}
.ftc-info { display: flex; flex-direction: column; gap: 3rpx; }
.ftc-title { font-size: 26rpx; font-weight: 800; color: #e2e8f0; }
.ftc-period { font-size: 19rpx; color: rgba(96,165,250,.6); }
.ftc-right {}
.ftc-badge {
  display: flex; align-items: center; gap: 8rpx;
  padding: 8rpx 20rpx; border-radius: 20rpx;
  border: 1.5rpx solid rgba(255,255,255,.1);
}
.ftc-badge.bull     { background: rgba(248,113,113,.12); border-color: rgba(248,113,113,.35); }
.ftc-badge.bull_w   { background: rgba(251,191,36,.10);  border-color: rgba(251,191,36,.3); }
.ftc-badge.bear     { background: rgba(52,211,153,.12);  border-color: rgba(52,211,153,.35); }
.ftc-badge.bear_w   { background: rgba(148,163,184,.1);  border-color: rgba(148,163,184,.25); }
.ftc-badge.sideways { background: rgba(96,165,250,.1);   border-color: rgba(96,165,250,.25); }
.ftc-badge-icon { font-size: 28rpx; }
.ftc-badge-txt  { font-size: 24rpx; font-weight: 800; color: #e2e8f0; }
.ftc-badge.bull     .ftc-badge-txt { color: #f87171; }
.ftc-badge.bull_w   .ftc-badge-txt { color: #fbbf24; }
.ftc-badge.bear     .ftc-badge-txt { color: #34d399; }
.ftc-badge.bear_w   .ftc-badge-txt { color: #94a3b8; }
.ftc-badge.sideways .ftc-badge-txt { color: #60a5fa; }

.ftc-detail-row {
  margin: 0 18rpx;
  background: rgba(7,9,15,.9);
  border: 1.5rpx solid rgba(59,130,246,.15);
  border-top: none;
  border-radius: 0 0 18rpx 18rpx;
  display: flex;
  padding: 12rpx 0 14rpx;
}
.ftc-detail-item {
  flex: 1; text-align: center;
  border-right: 1rpx solid rgba(255,255,255,.06);
}
.ftc-detail-item:last-child { border-right: none; }
.ftc-d-label { display: block; font-size: 18rpx; color: #475569; margin-bottom: 4rpx; }
.ftc-d-val   { display: block; font-size: 24rpx; font-weight: 800; color: #94a3b8; }
.ftc-d-val.red   { color: #f87171; }
.ftc-d-val.green { color: #34d399; }
.ftc-d-val.gray  { color: #475569; }



/* ─────────── K线图顶部区域 ─────────── */
.kline-header {
  margin: 16rpx 18rpx 0;
  background: rgba(59,130,246,.04);
  border: 1rpx solid rgba(59,130,246,.15);
  border-radius: 20rpx 20rpx 0 0;
  border-bottom: none;
  padding: 10rpx 14rpx 8rpx;
}

/* Pill胶囊周期切换 */
.kline-period-pills {
  display: flex; flex-direction: row; flex-wrap: wrap;
  gap: 8rpx; padding-bottom: 10rpx;
}
.kpill {
  display: inline-flex; align-items: center; justify-content: center;
  background: rgba(255,255,255,.05);
  border: 1.5rpx solid rgba(255,255,255,.1);
  border-radius: 999rpx;
  padding: 6rpx 22rpx;
  font-size: 24rpx; color: #64748b; font-weight: 600;
  transition: all .2s cubic-bezier(.34,1.56,.64,1);
  flex-shrink: 0;
}
.kpill:active { transform: scale(.93); }
.kpill-active {
  background: linear-gradient(135deg, rgba(59,130,246,.35), rgba(6,182,212,.25));
  border-color: #3b82f6; color: #e0f2fe; font-weight: 900;
  box-shadow: 0 0 10px rgba(59,130,246,.4);
  transform: scale(1.06);
}
.kpill-more {
  color: #fbbf24; border-color: rgba(251,191,36,.3);
  background: rgba(251,191,36,.06); font-size: 22rpx;
}

.kline-title-row {
  display: flex; align-items: center; justify-content: space-between;
}
.kline-title-txt { font-size: 26rpx; font-weight: 800; color: #f1f5f9; }

/* ─────────── 周期切换 ─────────── */
.period-bar {
  display: flex; white-space: nowrap; padding: 0 0 12rpx; gap: 8rpx;
  width: 100%;
}
.period-btn {
  display: inline-block; flex-shrink: 0;
  background: rgba(255,255,255,.04); border: 1rpx solid rgba(255,255,255,.08);
  border-radius: 20rpx; padding: 8rpx 20rpx; font-size: 24rpx; color: #64748b;
  transition: all .2s cubic-bezier(.34,1.56,.64,1);
}
.period-btn.active {
  background: linear-gradient(135deg, rgba(59,130,246,.28), rgba(6,182,212,.2));
  border-color: #3b82f6; color: #93c5fd; font-weight: 800;
  box-shadow: 0 0 14px rgba(59,130,246,.35);
  transform: scale(1.05);
}
.period-more-btn {
  display: inline-block; flex-shrink: 0;
  background: rgba(251,191,36,.08); border: 1rpx solid rgba(251,191,36,.25);
  border-radius: 20rpx; padding: 8rpx 18rpx; font-size: 22rpx; color: #fbbf24;
  font-weight: 700;
}

/* ─────────── 决策大卡 ─────────── */
.decision-card {
  margin: 0 18rpx 18rpx; border-radius: 28rpx; padding: 28rpx 22rpx 20rpx;
  border: 1rpx solid transparent; position: relative; overflow: hidden;
  backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);
}
.wait    { background: rgba(15,20,35,.9);           border-color: rgba(100,116,139,.2); }
.buy     { background: rgba(248,113,113,.07);        border-color: rgba(248,113,113,.4); }
.short_s { background: rgba(52,211,153,.07);         border-color: rgba(52,211,153,.4); }
.ok      { background: rgba(251,191,36,.07);         border-color: rgba(251,191,36,.35); }
.watch   { background: rgba(251,146,60,.07);         border-color: rgba(251,146,60,.3); }
.no      { background: rgba(100,116,139,.06);        border-color: rgba(100,116,139,.2); }

.decision-glow {
  position: absolute; top: -50rpx; right: -50rpx;
  width: 220rpx; height: 220rpx; border-radius: 50%;
  opacity: 0.1; pointer-events: none;
}
.decision-glow.buy     { background: radial-gradient(circle, #f87171, transparent); }
.decision-glow.short_s { background: radial-gradient(circle, #34d399, transparent); }
.decision-glow.ok      { background: radial-gradient(circle, #fbbf24, transparent); }
.decision-glow.watch   { background: radial-gradient(circle, #fb923c, transparent); }
.decision-glow.wait,.decision-glow.no { background: radial-gradient(circle, #3b82f6, transparent); }

/* AI角标 */
.ai-corner-tag {
  position: absolute; top: 0; left: 0;
  background: linear-gradient(90deg, #1d4ed8, #0891b2);
  padding: 5rpx 18rpx 5rpx 16rpx; border-radius: 0 0 16rpx 0;
  font-size: 18rpx; color: rgba(255,255,255,.9); font-weight: 700;
}

.decision-top { display: flex; align-items: center; gap: 18rpx; position: relative; z-index: 1; margin-top: 8rpx; }

.decision-face-wrap {
  width: 88rpx; height: 88rpx; border-radius: 50%; flex-shrink: 0;
  display: flex; align-items: center; justify-content: center;
  background: rgba(255,255,255,.05); border: 2rpx solid rgba(255,255,255,.1);
}
.decision-face-wrap.buy     { background: rgba(248,113,113,.12); border-color: rgba(248,113,113,.4); }
.decision-face-wrap.short_s { background: rgba(52,211,153,.12);  border-color: rgba(52,211,153,.4); }
.decision-face-wrap.ok      { background: rgba(251,191,36,.12);  border-color: rgba(251,191,36,.4); }
.decision-face-wrap.watch   { background: rgba(251,146,60,.12);  border-color: rgba(251,146,60,.4); }
.decision-face { font-size: 46rpx; }

.decision-text { flex: 1; }
.decision-verdict { display: block; font-size: 36rpx; font-weight: 800; color: #f1f5f9; }
.decision-sub     { display: block; font-size: 22rpx; color: #94a3b8; margin-top: 4rpx; line-height: 1.5; }
.decision-meta { display: flex; gap: 8rpx; flex-wrap: wrap; margin-top: 10rpx; }
.meta-tag {
  font-size: 18rpx; padding: 4rpx 12rpx; border-radius: 12rpx;
  background: rgba(255,255,255,.07); color: #94a3b8; font-weight: 600;
}
.meta-tag.long  { background: rgba(248,113,113,.18); color: #f87171; }
.meta-tag.short { background: rgba(52,211,153,.18);  color: #34d399; }
.meta-tag.accent { background: rgba(251,191,36,.2);  color: #fbbf24; }

.score-circle {
  display: flex; flex-direction: column; align-items: center; flex-shrink: 0;
  width: 72rpx; height: 72rpx; border-radius: 50%;
  background: rgba(255,255,255,.05); border: 2rpx solid rgba(59,130,246,.4);
  justify-content: center;
}
.score-circle.buy     { border-color: rgba(248,113,113,.6); }
.score-circle.short_s { border-color: rgba(52,211,153,.6); }
.score-circle.ok      { border-color: rgba(251,191,36,.6); }
.score-num { font-size: 36rpx; font-weight: 900; color: #fbbf24; line-height: 1; }
.score-den { font-size: 16rpx; color: #64748b; margin-top: -2rpx; }

.score-bar-wrap {
  margin: 18rpx 0 10rpx; height: 6rpx; background: rgba(255,255,255,.07);
  border-radius: 3rpx; overflow: hidden; position: relative; z-index: 1;
}
.score-bar-fill { height: 100%; border-radius: 3rpx; transition: width .6s cubic-bezier(.34,1.56,.64,1); }
.score-bar-fill.buy     { background: linear-gradient(90deg, #f87171, #fca5a5); }
.score-bar-fill.short_s { background: linear-gradient(90deg, #34d399, #6ee7b7); }
.score-bar-fill.ok      { background: linear-gradient(90deg, #60a5fa, #fbbf24); }
.score-bar-fill.watch   { background: linear-gradient(90deg, #fb923c, #fbbf24); }
.score-bar-fill.wait,.score-bar-fill.no { background: linear-gradient(90deg, #334155, #64748b); }

.decision-bottom { display: flex; justify-content: space-between; align-items: center; position: relative; z-index: 1; }
.score-stars { font-size: 26rpx; color: #fbbf24; letter-spacing: 3rpx; }
.score-label-wrap { display: flex; align-items: center; gap: 12rpx; }
.score-label { font-size: 22rpx; padding: 4rpx 16rpx; border-radius: 20rpx; font-weight: 700; }
.score-label.buy     { background: rgba(248,113,113,.2);  color: #f87171; }
.score-label.short_s { background: rgba(52,211,153,.2);   color: #34d399; }
.score-label.ok      { background: rgba(251,191,36,.2);   color: #fbbf24; }
.score-label.watch   { background: rgba(251,146,60,.2);   color: #fb923c; }
.score-label.no,.score-label.wait { background: rgba(100,116,139,.15); color: #64748b; }
.update-time { font-size: 18rpx; color: #334155; }

/* ─────────── 标题通用 ─────────── */
.section-title {
  display: flex; justify-content: space-between; align-items: center;
  margin: 20rpx 22rpx 12rpx; font-size: 28rpx; font-weight: 800; color: #f1f5f9;
}
.section-title-plain {
  margin: 18rpx 22rpx 12rpx; font-size: 28rpx; font-weight: 800; color: #f1f5f9;
  display: flex; align-items: center; justify-content: space-between;
}
.section-sub { font-size: 20rpx; color: #475569; font-weight: 400; }
.dir-tag { font-size: 22rpx; padding: 4rpx 18rpx; border-radius: 20rpx; font-weight: 700; }
.dir-tag.long  { background: rgba(248,113,113,.2); color: #f87171; }
.dir-tag.short { background: rgba(52,211,153,.2);  color: #34d399; }

/* ─────────── 信号详情 ─────────── */
.signal-detail {
  margin: 0 18rpx; background: rgba(15,20,35,.95); border-radius: 22rpx;
  border: 1rpx solid #1e293b; overflow: hidden; padding: 18rpx 18rpx 0;
}
.signal-detail.long  { border-color: rgba(248,113,113,.3); }
.signal-detail.short { border-color: rgba(52,211,153,.3); }
.detail-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12rpx; padding-bottom: 14rpx; }
.detail-cell { background: rgba(255,255,255,.03); border-radius: 14rpx; padding: 14rpx; }
.dc-label { display: block; font-size: 20rpx; color: #64748b; margin-bottom: 6rpx; }
.dc-val   { display: block; font-size: 30rpx; font-weight: 800; color: #f1f5f9; }
.dc-val.accent { color: #fbbf24; }
.dc-val.loss   { color: #fb923c; }

/* ─────────── 止盈止损常驻卡 ─────────── */
.tp-card {
  margin: 0 18rpx 20rpx;
  border-radius: 24rpx;
  overflow: hidden;
  border: 1rpx solid rgba(255,107,107,.25);
  background: rgba(15,25,41,.8);
}
.tp-card.long  { border-color: rgba(248,113,113,.35); }
.tp-card.short { border-color: rgba(52,211,153,.35); }
.tp-card.ref   { border-color: rgba(96,165,250,.25); }

.tp-card-header {
  padding: 18rpx 22rpx 14rpx;
  background: rgba(255,255,255,.03);
  border-bottom: 1rpx solid rgba(255,255,255,.06);
}
.tp-card-title-row {
  display: flex; align-items: center; gap: 10rpx; margin-bottom: 8rpx;
}
.tp-card-icon { font-size: 28rpx; }
.tp-card-title {
  font-size: 26rpx; font-weight: 800; color: #e2e8f0; flex: 1;
}
.tp-card-badge {
  padding: 4rpx 14rpx; border-radius: 20rpx; font-size: 20rpx; font-weight: 700;
}
.tp-card-badge.signal {
  background: rgba(248,113,113,.15); color: #fb923c; border: 1rpx solid rgba(248,113,113,.3);
}
.tp-card-badge.ref {
  background: rgba(96,165,250,.12); color: #60a5fa; border: 1rpx solid rgba(96,165,250,.25);
}
.tp-meta-row { display: flex; align-items: center; gap: 8rpx; flex-wrap: wrap; }
.tp-meta-item { font-size: 22rpx; color: #94a3b8; }
.tp-meta-item.loss   { color: #fb923c; }
.tp-meta-item.accent { color: #34d399; }
.tp-meta-item.muted  { color: #475569; }
.tp-meta-sep { font-size: 20rpx; color: #334155; }

.tp-levels {
  display: flex; border-top: 1rpx solid rgba(255,255,255,.05);
}
.tp-level-item {
  flex: 1; padding: 16rpx 0 14rpx; text-align: center;
  border-right: 1rpx solid rgba(255,255,255,.05);
}
.tp-level-item:last-child { border-right: none; }
.tp-level-item.sl { background: rgba(251,146,60,.04); }
.tp-level-item.t1 { background: rgba(52,211,153,.03); }
.tp-level-item.t2 { background: rgba(52,211,153,.05); }
.tp-level-item.t3 { background: rgba(52,211,153,.08); }

.tp-level-label {
  display: block; font-size: 18rpx; color: #64748b; margin-bottom: 4rpx;
}
.tp-level-val {
  display: block; font-size: 26rpx; font-weight: 900; margin-bottom: 3rpx;
}
.tp-level-val.loss   { color: #fb923c; }
.tp-level-val.profit { color: #34d399; }
.tp-level-pct {
  display: block; font-size: 18rpx; color: #475569;
}
.tp-no-signal-tip {
  padding: 12rpx 22rpx; text-align: center;
  font-size: 20rpx; color: #475569;
  border-top: 1rpx solid rgba(255,255,255,.04);
}

/* 旧tp-row（信号详情里不再用，保留兼容） */
.tp-row { display: flex; border-top: 1rpx solid #1e293b; }
.tp-item { flex: 1; padding: 14rpx 0; text-align: center; border-right: 1rpx solid #1e293b; }
.tp-item:last-child { border-right: none; }
.tp-label { display: block; font-size: 18rpx; color: #64748b; margin-bottom: 4rpx; }
.tp-val   { display: block; font-size: 24rpx; font-weight: 800; }
.tp-val.long  { color: #f87171; }
.tp-val.short { color: #34d399; }



/* ─────────── 指标卡 2×4 ─────────── */
.ind-grid {
  display: grid; grid-template-columns: repeat(4, 1fr);
  gap: 10rpx; margin: 0 18rpx;
}
.ind-card {
  background: rgba(15,20,35,.9); border: 1rpx solid #1e293b;
  border-radius: 18rpx; padding: 14rpx 8rpx 10rpx; text-align: center;
  position: relative; overflow: hidden;
}
.ind-card.long  { background: rgba(248,113,113,.07); border-color: rgba(248,113,113,.25); }
.ind-card.short { background: rgba(52,211,153,.07);  border-color: rgba(52,211,153,.25); }
.ind-top { display: flex; align-items: center; justify-content: center; gap: 6rpx; margin-bottom: 4rpx; }
.ind-dot { width: 10rpx; height: 10rpx; border-radius: 50%; flex-shrink: 0; }
.ind-dot.red   { background: #f87171; box-shadow: 0 0 4px #f87171; }
.ind-dot.green { background: #34d399; box-shadow: 0 0 4px #34d399; }
.ind-dot.gray  { background: #475569; }
.ind-name { font-size: 17rpx; color: #64748b; }
.ind-val  { display: block; font-size: 28rpx; font-weight: 900; color: #f1f5f9; margin: 2rpx 0; }
.ind-val.long  { color: #f87171; }
.ind-val.short { color: #34d399; }
.ind-tip  { display: block; font-size: 14rpx; color: #475569; line-height: 1.4; min-height: 2em; }
.ind-prog-wrap { margin: 8rpx 5rpx 4rpx; height: 4rpx; background: rgba(255,255,255,.05); border-radius: 2rpx; overflow: hidden; }
.ind-prog-fill { height: 100%; border-radius: 2rpx; background: #334155; }
.ind-prog-fill.long  { background: linear-gradient(90deg, #f87171, #fca5a5); }
.ind-prog-fill.short { background: linear-gradient(90deg, #34d399, #6ee7b7); }
.ind-state { display: block; font-size: 15rpx; margin-top: 2rpx; }
.ind-state.red   { color: #f87171; }
.ind-state.green { color: #34d399; }
.ind-state.gray  { color: #475569; }

/* ─────────── 多空条件感知 ─────────── */
.cond-wrap {
  display: flex; margin: 0 18rpx;
  background: rgba(15,20,35,.9); border-radius: 22rpx; border: 1rpx solid #1e293b; overflow: hidden;
}
.cond-col { flex: 1; padding: 16rpx 12rpx; }
.cond-divider { width: 1rpx; background: #1e293b; }
.cond-col-title { font-size: 24rpx; font-weight: 800; margin-bottom: 12rpx; }
.long-color  { color: #f87171; }
.short-color { color: #34d399; }
.cond-item { display: flex; gap: 8rpx; align-items: flex-start; margin-bottom: 12rpx; }
.cond-icon { font-size: 20rpx; line-height: 1.5; flex-shrink: 0; }
.cond-text { display: flex; flex-direction: column; }
.cond-label { font-size: 21rpx; color: #64748b; font-weight: 600; }
.cond-tip   { font-size: 17rpx; color: #334155; margin-top: 2rpx; }
.cond-item.ok .cond-label { color: #f1f5f9; }
.cond-item.ok .cond-tip   { color: #34d399; }
.cond-score-bar {
  display: flex; align-items: center; gap: 10rpx;
  height: 6rpx; background: rgba(255,255,255,.05); border-radius: 3rpx; overflow: hidden;
  position: relative; margin-top: 4rpx;
}
.cond-score-fill { height: 100%; border-radius: 3rpx; transition: width .4s; }
.cond-score-fill.long  { background: linear-gradient(90deg, #f87171, #fca5a5); }
.cond-score-fill.short { background: linear-gradient(90deg, #34d399, #6ee7b7); }
.cond-score-txt { position: absolute; right: 0; top: -22rpx; font-size: 18rpx; color: #475569; }

/* ─────────── 付费墙 ─────────── */
.paywall-full {
  margin: 0 18rpx 24rpx; border-radius: 28rpx; overflow: hidden;
  background: linear-gradient(180deg, #0a1628 0%, #07090f 100%);
  border: 1rpx solid rgba(59,130,246,.3);
  padding: 32rpx 24rpx 28rpx;
}

.pw-ai-header { text-align: center; padding-bottom: 24rpx; }
.pw-ai-circle {
  width: 96rpx; height: 96rpx; border-radius: 50%; margin: 0 auto 16rpx;
  background: linear-gradient(135deg, #1d4ed8, #0891b2);
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 0 30px rgba(59,130,246,.5);
}
.pw-ai-icon { font-size: 48rpx; }
.pw-ai-title { display: block; font-size: 34rpx; font-weight: 900; color: #93c5fd; letter-spacing: 1rpx; }
.pw-ai-sub { display: block; font-size: 22rpx; color: #6b7280; margin-top: 6rpx; }

.pw-trial-end {
  background: rgba(59,130,246,.08); border: 1rpx solid rgba(59,130,246,.3);
  border-radius: 16rpx; padding: 18rpx 20rpx; margin-bottom: 24rpx; text-align: center;
}
.pw-trial-end-icon { display: block; font-size: 36rpx; margin-bottom: 8rpx; }
.pw-trial-end-txt { display: block; font-size: 28rpx; font-weight: 800; color: #93c5fd; margin-bottom: 6rpx; }
.pw-trial-end-sub { display: block; font-size: 22rpx; color: #64748b; line-height: 1.5; }

.pw-features { margin-bottom: 24rpx; }
.pw-feat-item {
  display: flex; align-items: center; gap: 16rpx;
  padding: 14rpx 0; border-bottom: 1rpx solid rgba(255,255,255,.05);
}
.pw-feat-item:last-child { border-bottom: none; }
.pw-feat-icon { font-size: 36rpx; flex-shrink: 0; }
.pw-feat-text { flex: 1; }
.pw-feat-title { display: block; font-size: 26rpx; font-weight: 700; color: #e2e8f0; }
.pw-feat-desc  { display: block; font-size: 20rpx; color: #64748b; margin-top: 3rpx; }

.pw-testimonial {
  background: rgba(59,130,246,.1); border-left: 4rpx solid #3b82f6;
  border-radius: 0 14rpx 14rpx 0; padding: 16rpx 18rpx; margin-bottom: 24rpx;
}
.pw-test-quote { display: block; font-size: 24rpx; color: #93c5fd; line-height: 1.6; font-style: italic; }
.pw-test-author { display: block; font-size: 20rpx; color: #64748b; margin-top: 8rpx; text-align: right; }

.pw-pricing { display: flex; gap: 12rpx; margin-bottom: 24rpx; }
.pw-price-card {
  flex: 1; border-radius: 18rpx; padding: 18rpx 8rpx; text-align: center;
  border: 1rpx solid rgba(255,255,255,.1); background: rgba(255,255,255,.03);
  position: relative; overflow: hidden;
}
.pw-price-card.month { border-color: rgba(96,165,250,.3); }
.pw-price-card.year  { border-color: rgba(251,191,36,.4); background: rgba(251,191,36,.05); }
.pw-price-card.life  { border-color: rgba(129,140,248,.3); }
.pw-price-hot-tag {
  position: absolute; top: 0; left: 50%; transform: translateX(-50%);
  background: linear-gradient(90deg, #d97706, #fbbf24);
  font-size: 18rpx; color: #fff; font-weight: 700;
  padding: 4rpx 16rpx; border-radius: 0 0 12rpx 12rpx;
}
.pw-price-label { display: block; font-size: 22rpx; color: #94a3b8; margin-bottom: 8rpx; margin-top: 24rpx; }
.pw-price-amount { display: flex; align-items: baseline; justify-content: center; }
.pw-price-sym { font-size: 22rpx; color: #f1f5f9; font-weight: 700; margin-right: 2rpx; }
.pw-price-num { font-size: 44rpx; font-weight: 900; color: #f1f5f9; line-height: 1; }
.pw-price-card.year .pw-price-num { color: #ffd43b; }
.pw-price-desc { display: block; font-size: 18rpx; color: #64748b; margin-top: 6rpx; }

.pw-cta-btn {
  background: linear-gradient(135deg, #1d4ed8, #0891b2, #3b82f6);
  border-radius: 22rpx; padding: 24rpx 0; text-align: center; margin-bottom: 20rpx;
  box-shadow: 0 8px 30px rgba(59,130,246,.45);
  animation: cta-pulse 2s infinite;
}
@keyframes cta-pulse {
  0%,100%{box-shadow:0 8px 30px rgba(59,130,246,.45)}
  50%{box-shadow:0 8px 40px rgba(59,130,246,.7),0 0 60px rgba(6,182,212,.3)}
}
.pw-cta-text { font-size: 30rpx; font-weight: 900; color: #fff; letter-spacing: 1rpx; }

.pw-code-area { border-top: 1rpx solid rgba(255,255,255,.06); padding-top: 20rpx; }
.pw-code-title { display: block; font-size: 22rpx; color: #64748b; margin-bottom: 12rpx; text-align: center; }
.pw-code-row { display: flex; gap: 12rpx; }
.pw-code-input {
  flex: 1; background: rgba(255,255,255,.04); border: 1rpx solid rgba(255,255,255,.12);
  border-radius: 14rpx; padding: 16rpx 18rpx; font-size: 26rpx; color: #f1f5f9;
  letter-spacing: 2rpx;
}
.pw-code-btn {
  background: linear-gradient(135deg, #1d4ed8, #0891b2);
  border-radius: 14rpx; padding: 16rpx 28rpx;
  font-size: 26rpx; color: #fff; font-weight: 700; flex-shrink: 0;
}
.pw-code-hint {
  display: block; text-align: center; margin-top: 14rpx;
  font-size: 24rpx; color: #1e293b; letter-spacing: 4rpx;
}

/* ─────────── K线图 ─────────── */
.chart-legend { display: flex; align-items: center; gap: 8rpx; font-size: 18rpx; }
.leg-boll-u { color: #818cf8; }
.leg-boll-l { color: #10b981; }
.leg-ma5    { color: #fb923c; }
.leg-ma10   { color: #60a5fa; }
.kview-badge {
  font-size: 18rpx; color: #3b82f6;
  background: rgba(59,130,246,.1); border: 1rpx solid rgba(59,130,246,.3);
  padding: 3rpx 14rpx; border-radius: 20rpx;
}
.kcanvas-wrap {
  margin: 0 18rpx; position: relative;
  background: #0a0e17; border-radius: 0 0 20rpx 20rpx;
  border: 1rpx solid rgba(59,130,246,.15); border-top: none; overflow: hidden;
}
.kcanvas { width: 100%; height: 580rpx; display: block; }
.kcanvas { width: 100%; height: 580rpx; display: block; }
.kcanvas-hint {
  position: absolute; bottom: 8rpx; left: 50%;
  transform: translateX(-50%);
  font-size: 16rpx; color: rgba(100,116,139,.45);
  pointer-events: none; white-space: nowrap;
}
.ktooltip {
  position: absolute; top: 10rpx;
  background: rgba(10,14,23,.97);
  border: 1rpx solid #1e293b; border-radius: 12rpx;
  padding: 10rpx 16rpx; min-width: 136rpx;
  pointer-events: none; z-index: 10;
  box-shadow: 0 4px 24px rgba(0,0,0,.7);
}
.ktt-time { font-size: 18rpx; color: #64748b; display: block; margin-bottom: 6rpx; }
.ktt-row  { display: flex; justify-content: space-between; gap: 14rpx; margin: 2rpx 0; }
.ktt-l    { font-size: 18rpx; color: #334155; }
.ktt-v    { font-size: 18rpx; color: #e2e8f0; font-weight: 700; }
.ktt-v.up { color: #f87171; }
.ktt-v.dn { color: #34d399; }
.ktt-div  { height: 1rpx; background: #1e293b; margin: 6rpx 0; }

/* ─────────── 风控 ─────────── */
.risk-bar {
  display: flex; justify-content: space-between; align-items: center;
  margin: 16rpx 18rpx; padding: 12rpx 18rpx; border-radius: 14rpx;
  background: rgba(60,165,250,.06); border: 1rpx solid rgba(60,165,250,.2);
}
.risk-bar.cooldown { background: rgba(251,146,60,.06); border-color: rgba(251,146,60,.3); }
.risk-bar.max_loss { background: rgba(248,113,113,.06); border-color: rgba(248,113,113,.3); }
.risk-left { display: flex; align-items: center; gap: 10rpx; }
.risk-icon { font-size: 22rpx; }
.risk-txt { font-size: 22rpx; color: #60a5fa; font-weight: 600; }
.risk-bar.cooldown .risk-txt { color: #fb923c; }
.risk-bar.max_loss .risk-txt { color: #f87171; }
.risk-right { font-size: 20rpx; color: #64748b; }

/* ─────────── 底部 ─────────── */
.footer { text-align: center; padding: 24rpx 0 50rpx; }
.footer-logo {
  display: block; font-size: 24rpx; font-weight: 800; margin-bottom: 8rpx;
  background: linear-gradient(90deg, #3b82f6, #06b6d4);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
}
.footer-txt { display: block; font-size: 20rpx; color: #3e5068; line-height: 1.8; }
.footer-disclaimer {
  display: block; font-size: 18rpx; color: #4a5568;
  margin-top: 8rpx; line-height: 1.6;
}

/* ─────────── 免责声明弹框 ─────────── */
.disclaimer-mask {
  position: fixed; inset: 0; background: rgba(0,0,0,.85); z-index: 200;
  display: flex; align-items: center; justify-content: center;
}
.disclaimer-dialog {
  width: 640rpx; background: #0a1628;
  border: 1rpx solid rgba(59,130,246,.4);
  border-radius: 28rpx; overflow: hidden;
  box-shadow: 0 20px 60px rgba(0,0,0,.6), 0 0 40px rgba(59,130,246,.15);
}
.disc-header {
  padding: 28rpx 28rpx 16rpx;
  background: linear-gradient(135deg, rgba(59,130,246,.15), rgba(6,182,212,.1));
  border-bottom: 1rpx solid rgba(59,130,246,.2);
}
.disc-title {
  display: block; font-size: 32rpx; font-weight: 900; color: #f59e0b;
  text-align: center; margin-bottom: 6rpx;
}
.disc-sub {
  display: block; font-size: 22rpx; color: #64748b; text-align: center;
}
.disc-scroll {
  height: 300rpx; padding: 20rpx 28rpx;
}
.disc-body {
  font-size: 24rpx; color: #94a3b8; line-height: 1.9;
  display: block; white-space: pre-wrap;
}
.disc-btn-row {
  display: flex; padding: 20rpx 24rpx 28rpx; gap: 16rpx;
}
.disc-reject-btn {
  flex: 1; padding: 22rpx 0; text-align: center;
  background: rgba(255,255,255,.05); border: 1rpx solid #1e293b;
  border-radius: 18rpx; font-size: 26rpx; color: #64748b;
}
.disc-agree-btn {
  flex: 2; padding: 22rpx 0; text-align: center;
  background: linear-gradient(135deg, #1d4ed8, #0891b2);
  border-radius: 18rpx; font-size: 26rpx; font-weight: 800; color: #fff;
  box-shadow: 0 4px 20px rgba(59,130,246,.4);
}

/* ─────────── 付费墙联系提示 ─────────── */
.pw-contact-hint {
  display: block; font-size: 22rpx; color: #64748b;
  text-align: center; margin-top: 12rpx; margin-bottom: 4rpx;
}


/* ─────────── 会员升级抽屉 ─────────── */
.vip-drawer-mask {
  position: fixed; inset: 0; background: rgba(0,0,0,.65); z-index: 150;
  display: flex; align-items: flex-end; justify-content: center;
}
.vip-drawer {
  width: 100%; background: #0a1628;
  border-radius: 32rpx 32rpx 0 0;
  border-top: 1.5rpx solid rgba(59,130,246,.35);
  padding: 28rpx 26rpx 60rpx;
  box-shadow: 0 -10px 50px rgba(0,0,0,.6), 0 0 40px rgba(59,130,246,.1);
}
.vip-drawer-header {
  display: flex; align-items: center; justify-content: space-between; margin-bottom: 22rpx;
}
.vip-drawer-title { font-size: 34rpx; font-weight: 900; color: #f1f5f9; }
.vip-drawer-close {
  width: 52rpx; height: 52rpx; border-radius: 50%;
  background: rgba(255,255,255,.07); border: 1rpx solid rgba(255,255,255,.12);
  display: flex; align-items: center; justify-content: center;
  font-size: 26rpx; color: #64748b;
}

.vip-status-row {
  display: flex; align-items: center; gap: 12rpx;
  background: rgba(59,130,246,.08); border: 1rpx solid rgba(59,130,246,.2);
  border-radius: 16rpx; padding: 14rpx 18rpx; margin-bottom: 22rpx;
}
.vip-status-icon { font-size: 30rpx; }
.vip-status-txt  { font-size: 24rpx; color: #93c5fd; font-weight: 600; }

.vip-price-row { display: flex; gap: 14rpx; margin-bottom: 24rpx; }
.vip-price-item {
  flex: 1; border-radius: 20rpx; padding: 18rpx 8rpx 14rpx; text-align: center;
  border: 1.5rpx solid rgba(255,255,255,.1); background: rgba(255,255,255,.03);
  position: relative; overflow: hidden;
}
.vip-price-item.month { border-color: rgba(96,165,250,.3); }
.vip-price-item.year  { border-color: rgba(251,191,36,.4); background: rgba(251,191,36,.05); }
.vip-price-item.life  { border-color: rgba(129,140,248,.3); }
.vip-price-hot {
  position: absolute; top: 0; left: 50%; transform: translateX(-50%);
  background: linear-gradient(90deg, #d97706, #fbbf24);
  font-size: 17rpx; color: #fff; font-weight: 700;
  padding: 4rpx 14rpx; border-radius: 0 0 12rpx 12rpx;
}
.vip-price-name { display: block; font-size: 22rpx; color: #94a3b8; margin-bottom: 6rpx; margin-top: 20rpx; }
.vip-price-num-wrap { display: flex; align-items: baseline; justify-content: center; }
.vip-price-sym { font-size: 20rpx; color: #f1f5f9; font-weight: 700; margin-right: 2rpx; }
.vip-price-num { font-size: 42rpx; font-weight: 900; color: #f1f5f9; line-height: 1; }
.vip-price-item.year .vip-price-num { color: #ffd43b; }
.vip-price-desc { display: block; font-size: 17rpx; color: #64748b; margin-top: 4rpx; }

.vip-cta-btn {
  background: linear-gradient(135deg, #1d4ed8, #0891b2, #3b82f6);
  border-radius: 20rpx; padding: 22rpx 0; text-align: center; margin-bottom: 12rpx;
  box-shadow: 0 6px 24px rgba(59,130,246,.4);
}
.vip-cta-txt { font-size: 30rpx; font-weight: 900; color: #fff; letter-spacing: 1rpx; }
.vip-cta-hint {
  display: block; font-size: 20rpx; color: #64748b; text-align: center; margin-bottom: 22rpx;
}

.vip-code-area {
  border-top: 1rpx solid rgba(255,255,255,.06); padding-top: 20rpx;
}
.vip-code-title { display: block; font-size: 22rpx; color: #64748b; margin-bottom: 12rpx; text-align: center; }
.vip-code-row { display: flex; gap: 12rpx; }
.vip-code-input {
  flex: 1; background: rgba(255,255,255,.04); border: 1rpx solid rgba(255,255,255,.12);
  border-radius: 14rpx; padding: 16rpx 18rpx; font-size: 26rpx; color: #f1f5f9;
  letter-spacing: 2rpx;
}
.vip-code-btn {
  background: linear-gradient(135deg, #1d4ed8, #0891b2);
  border-radius: 14rpx; padding: 16rpx 28rpx;
  font-size: 26rpx; color: #fff; font-weight: 700; flex-shrink: 0;
}
.vip-pwd-hint {
  display: block; text-align: right; margin-top: 12rpx;
  font-size: 20rpx; color: rgba(71,85,105,.4); letter-spacing: 4rpx;
}
.error-bar {
  margin: 0 18rpx 24rpx; padding: 18rpx 20rpx;
  background: rgba(248,113,113,.07); border: 1rpx solid rgba(248,113,113,.3);
  border-radius: 16rpx;
}
.error-bar text { display: block; font-size: 24rpx; color: #fca5a5; }
.error-hint { font-size: 20rpx !important; color: #64748b !important; margin-top: 6rpx; }

/* ─────────── 密码弹框 ─────────── */
.pwd-mask {
  position: fixed; inset: 0; background: rgba(0,0,0,.7); z-index: 100;
  display: flex; align-items: center; justify-content: center;
}
.pwd-dialog {
  width: 580rpx; background: #0f1929; border: 1rpx solid #1e293b;
  border-radius: 24rpx; padding: 36rpx 32rpx;
}
.pwd-title { display: block; font-size: 30rpx; font-weight: 800; color: #f1f5f9; margin-bottom: 20rpx; text-align: center; }
.pwd-input {
  width: 100%; background: rgba(255,255,255,.04); border: 1rpx solid #1e293b;
  border-radius: 14rpx; padding: 16rpx 18rpx; font-size: 28rpx; color: #f1f5f9;
  box-sizing: border-box; margin-bottom: 16rpx;
}
.pwd-submit {
  background: linear-gradient(135deg, #1d4ed8, #0891b2);
  border-radius: 14rpx; padding: 16rpx 0; text-align: center;
  font-size: 28rpx; font-weight: 800; color: #fff;
}
