/* pages/index/index.wxss  v9.1  蓝黑深空版 */
/* 主题色：深蓝#3b82f6 / 青色#06b6d4 / 淡紫蓝#818cf8 / 薄荷#10b981 / 金#fbbf24 */

/* ─────────── 全局基础 ─────────── */
page {
  background: #07090f;
  color: #e4ecf7;
  font-size: 28rpx;
  font-family: -apple-system, 'PingFang SC', 'Helvetica Neue', sans-serif;
  -webkit-font-smoothing: antialiased;
}

/* ─────────── 合并顶部导航栏 ─────────── */
.top-header {
  background: linear-gradient(180deg, #06091c 0%, #040714 100%);
  border-bottom: 1rpx solid rgba(255,198,0,.2);
  padding: 22rpx 24rpx 18rpx;
}
.top-header-inner {
  display: flex; align-items: center; gap: 20rpx;
}

/* ── 大饼LOGO圆形硬币 ── */
.top-logo-wrap {
  position: relative; flex-shrink: 0;
  width: 88rpx; height: 88rpx;
  display: flex; align-items: center; justify-content: center;
}
.top-logo-coin {
  width: 82rpx; height: 82rpx; border-radius: 50%;
  background: linear-gradient(145deg, #ffd700 0%, #ff9500 40%, #ffb300 70%, #ffd700 100%);
  display: flex; align-items: center; justify-content: center;
  box-shadow:
    0 0 20px rgba(255,180,0,.7),
    0 0 40px rgba(255,140,0,.35),
    inset 0 2rpx 6rpx rgba(255,255,255,.4),
    inset 0 -2rpx 4rpx rgba(180,100,0,.3);
  position: relative; z-index: 2;
}
.top-logo-inner {
  font-size: 46rpx; font-weight: 900; color: #7a3f00;
  text-shadow: 0 1rpx 2rpx rgba(255,255,255,.4);
  line-height: 1;
}
.logo-spin {
  animation: coin-wobble 3s ease-in-out infinite;
}
@keyframes coin-wobble {
  0%,100% { transform: scale(1) rotate(-3deg); }
  25%      { transform: scale(1.08) rotate(3deg); }
  50%      { transform: scale(1.04) rotate(-2deg); }
  75%      { transform: scale(1.06) rotate(2deg); }
}
.top-logo-pulse {
  position: absolute; width: 88rpx; height: 88rpx; border-radius: 50%;
  background: transparent;
  border: 2rpx solid rgba(255,190,0,.5);
  animation: logo-ring-pulse 2s ease-out infinite;
}
@keyframes logo-ring-pulse {
  0%   { transform: scale(.9);  opacity: .9; }
  100% { transform: scale(1.5); opacity: 0; }
}

.top-title-block { flex: 1; }
.top-title-main {
  display: block; font-size: 38rpx; font-weight: 900;
  background: linear-gradient(90deg, #ffd700 0%, #ffb300 40%, #ff9f0a 100%);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  letter-spacing: 2rpx;
  text-shadow: none;
}
.top-title-live {
  display: flex; align-items: center; gap: 8rpx; margin-top: 6rpx;
}
.title-live-dot {
  width: 10rpx; height: 10rpx; border-radius: 50%; flex-shrink: 0;
  background: #22c55e; box-shadow: 0 0 8px rgba(34,197,94,.9);
  animation: live-pulse 1.5s ease-in-out infinite;
}
@keyframes live-pulse {
  0%, 100% { opacity: 1; box-shadow: 0 0 6px rgba(34,197,94,.8); }
  50%       { opacity: .45; box-shadow: 0 0 14px rgba(34,197,94,.3); }
}
.top-title-sub {
  display: inline; font-size: 21rpx; color: rgba(255,180,80,.75);
  font-weight: 600;
}
.top-right-area { display: flex; align-items: center; gap: 14rpx; }
.live-dot {
  width: 12rpx; height: 12rpx; border-radius: 50%; background: #10b981;
  box-shadow: 0 0 8px #10b981; animation: pulse-dot 2s infinite;
}
@keyframes pulse-dot { 0%,100%{box-shadow:0 0 6px #10b981} 50%{box-shadow:0 0 14px #10b981,0 0 20px rgba(16,185,129,.4)} }
.live-dot.loading { background: #fbbf24; box-shadow: 0 0 8px #fbbf24; animation: blink .7s infinite; }
@keyframes blink { 0%,100%{opacity:1} 50%{opacity:.2} }
.nav-refresh-btn {
  background: rgba(255,180,0,.1); border: 1rpx solid rgba(255,180,0,.35);
  padding: 8rpx 22rpx; border-radius: 20rpx; font-size: 26rpx; color: #fbbf24;
  font-weight: 700;
}
.top-vip-btn {
  width: 48rpx; height: 48rpx; border-radius: 50%;
  background: rgba(251,191,36,.12); border: 1.5rpx solid rgba(251,191,36,.35);
  display: flex; align-items: center; justify-content: center; font-size: 26rpx;
}
/* 兼容旧 ai-banner 类（隐藏） */
.ai-banner { display: none; }
/* 兼容旧 navbar（隐藏） */
.navbar { display: none; }
/* 兼容旧 top-frog-wrap */
.top-frog-wrap { display: none; }

/* ─────────── 60秒倒计时条 ─────────── */
.trial-bar {
  position: relative; height: 60rpx; overflow: hidden;
  background: #090e1a;
}
.trial-bar-fill {
  position: absolute; left: 0; top: 0; bottom: 0;
  background: linear-gradient(90deg, #1d4ed8 0%, #0891b2 50%, #3b82f6 100%);
  transition: width 1s linear;
  opacity: .55;
}
.trial-bar-content {
  position: relative; z-index: 1;
  display: flex; align-items: center; justify-content: center;
  height: 100%; gap: 12rpx;
}
.trial-icon { font-size: 24rpx; }
.trial-txt { font-size: 24rpx; color: #93c5fd; font-weight: 600; }
.trial-secs { color: #fff; font-weight: 900; font-size: 28rpx; }
.trial-secs.urgent { color: #f87171; animation: pulse-red 0.5s infinite alternate; }
@keyframes pulse-red { from { opacity:.6 } to { opacity:1 } }
.trial-cta {
  font-size: 22rpx; color: #fbbf24; font-weight: 700;
  background: rgba(251,191,36,.15); border-radius: 20rpx; padding: 4rpx 14rpx;
}

/* ─────────── 导航栏（兼容旧代码，已隐藏） ─────────── */
.navbar { display: none; }
.navbar-left { display: none; }
.navbar-right { display: none; }
.nav-icon { display: none; }
.nav-title { display: none; }
.nav-sub { display: none; }


/* ─────────── AI评分+指标 合并大卡 ─────────── */
.ai-ind-card {
  margin: 0 18rpx 18rpx;
  background: linear-gradient(160deg, rgba(10,14,28,.96) 0%, rgba(15,20,40,.92) 100%);
  border: 1rpx solid rgba(59,130,246,.2);
  border-radius: 24rpx;
  padding: 20rpx 18rpx 16rpx;
  box-shadow: 0 4px 24px rgba(0,0,0,.4);
}
/* 顶部评分行 */
.ai-ind-top {
  display: flex; align-items: flex-start; gap: 20rpx; margin-bottom: 4rpx;
}
.ai-ind-right {
  flex: 1; display: flex; flex-direction: column; gap: 7rpx; padding-top: 4rpx;
}
.ai-ind-verdict {
  font-size: 34rpx; font-weight: 900; color: #64748b;
}
.ai-ind-verdict.buy  { color: #f87171; }
.ai-ind-verdict.short_s { color: #34d399; }
.ai-ind-verdict.ok   { color: #60a5fa; }
.ai-ind-verdict.watch{ color: #fbbf24; }
.ai-ind-verdict.wait, .ai-ind-verdict.no { color: #475569; }
.ai-ind-signal {
  font-size: 26rpx; font-weight: 800; color: #60a5fa; letter-spacing: 1rpx;
}
/* 入场门槛三行 */
.ai-ind-threshold {
  display: flex; flex-direction: row; flex-wrap: wrap; gap: 8rpx; margin-top: 4rpx;
}
.ai-thr-item {
  display: flex; align-items: center; gap: 6rpx; opacity: .45;
  transition: opacity .3s;
}
.ai-thr-item.active-strong, .ai-thr-item.active-ok, .ai-thr-item.active-wait {
  opacity: 1;
}
.ai-thr-dot {
  width: 12rpx; height: 12rpx; border-radius: 50%; flex-shrink: 0;
}
.ai-thr-dot.strong { background: #f87171; box-shadow: 0 0 6px rgba(248,113,113,.6); }
.ai-thr-dot.ok     { background: #60a5fa; box-shadow: 0 0 6px rgba(96,165,250,.6); }
.ai-thr-dot.wait   { background: #475569; }
.ai-thr-txt { font-size: 20rpx; color: #94a3b8; font-weight: 600; }
.ai-thr-item.active-strong .ai-thr-txt { color: #f87171; font-weight: 900; }
.ai-thr-item.active-ok .ai-thr-txt     { color: #60a5fa; font-weight: 900; }
.ai-thr-item.active-wait .ai-thr-txt   { color: #64748b; }

/* 分割线 */
.ai-ind-divider {
  display: flex; align-items: center; gap: 12rpx;
  margin: 14rpx 0 12rpx; 
  border-top: 1rpx solid rgba(59,130,246,.12);
  padding-top: 12rpx;
}
.ai-ind-divider-txt {
  font-size: 22rpx; color: #475569; font-weight: 700; letter-spacing: 1rpx;
}

/* 指标分值角标 */
.ind-score-badge {
  position: absolute; top: 6rpx; right: 6rpx;
  background: rgba(255,255,255,.06);
  border: 1rpx solid rgba(255,255,255,.1);
  border-radius: 8rpx; padding: 2rpx 7rpx;
}
.ind-score-badge.has-score {
  background: rgba(59,130,246,.18); border-color: rgba(59,130,246,.4);
}
.ind-score-num {
  font-size: 18rpx; font-weight: 900; color: #64748b;
}
.ind-score-badge.has-score .ind-score-num { color: #93c5fd; }

/* 旧的顶部栏样式保留（兼容，不影响新卡） */
.ai-score-top-bar {
  display: none;
}
.ai-score-top-info {
  flex: 1; display: flex; flex-direction: column; gap: 6rpx;
}
.ai-score-top-label {
  font-size: 32rpx; font-weight: 900; color: #64748b;
}
.ai-score-top-label.buy, .ai-score-top-label.signal-long { color: #f87171; }
.ai-score-top-label.short_s, .ai-score-top-label.signal-short { color: #34d399; }
.ai-score-top-label.ok { color: #60a5fa; }
.ai-score-top-label.watch { color: #fbbf24; }
.ai-score-top-label.wait, .ai-score-top-label.no { color: #475569; }
.ai-score-top-hint {
  font-size: 22rpx; color: #475569;
}
.ai-score-signal-dir {
  font-size: 26rpx; font-weight: 800;
  color: #60a5fa;
  letter-spacing: 1rpx;
}
.ai-score-bar-wrap {
  height: 8rpx; background: rgba(255,255,255,.08); border-radius: 8rpx; overflow: hidden; width: 100%;
}
.ai-score-bar-fill {
  height: 100%; border-radius: 8rpx;
  background: linear-gradient(90deg, #3b82f6, #06b6d4);
  transition: width .5s cubic-bezier(.34,1.56,.64,1);
}
.ai-score-bar-fill.buy, .ai-score-bar-fill.signal-long {
  background: linear-gradient(90deg, #f87171, #fb923c);
}
.ai-score-bar-fill.short_s, .ai-score-bar-fill.signal-short {
  background: linear-gradient(90deg, #34d399, #06b6d4);
}
.ai-score-bar-fill.ok { background: linear-gradient(90deg, #60a5fa, #818cf8); }
.ai-score-bar-fill.watch { background: linear-gradient(90deg, #fbbf24, #f59e0b); }

/* ─────────── 价格大头（最顶部紧凑横排） ─────────── */
.price-hero {
  display: flex; flex-direction: row; align-items: center; gap: 16rpx;
  padding: 14rpx 24rpx 10rpx;
  background: linear-gradient(180deg, rgba(8,13,26,.9) 0%, rgba(8,13,26,.5) 100%);
  flex-wrap: wrap;
}
.price-hero-left { display: flex; align-items: center; flex-shrink: 0; }
.price-hero-right { display: flex; flex-direction: column; gap: 8rpx; flex: 1; }
.price-main { font-size: 52rpx; font-weight: 900; letter-spacing: 1rpx; color: #e4ecf7; flex-shrink: 0; }

.price-main.up   { color: #f87171; }
.price-main.down { color: #34d399; }



.price-badges { display: flex; gap: 8rpx; flex-wrap: wrap; }
.price-badge {
  font-size: 20rpx; padding: 4rpx 12rpx; border-radius: 12rpx; font-weight: 700;
}
.price-badge.up   { background: rgba(248,113,113,.18); color: #f87171; }
.price-badge.down { background: rgba(52,211,153,.18);  color: #34d399; }
.price-badge-plain {
  font-size: 20rpx; padding: 4rpx 12rpx; border-radius: 12rpx;
  background: rgba(255,255,255,.06); color: #94a3b8;
}

/* AI评分环（右上角，小版，保留兼容） */
.ai-score-ring {
  display: flex; flex-direction: column; align-items: center;
  width: 100rpx; height: 100rpx; border-radius: 50%;
  background: conic-gradient(#3b82f6 0%, #06b6d4 60%, rgba(255,255,255,.06) 60%);
  justify-content: center;
  box-shadow: 0 0 20px rgba(59,130,246,.4);
  position: relative;
}
.ai-score-ring::before {
  content: ''; position: absolute; width: 76rpx; height: 76rpx;
  border-radius: 50%; background: #07090f;
}
.ai-ring-num {
  position: relative; z-index: 1; font-size: 34rpx; font-weight: 900;
  color: #93c5fd; line-height: 1;
}
.ai-ring-den {
  position: relative; z-index: 1; font-size: 14rpx; color: #64748b; margin-top: -2rpx;
}
.ai-ring-label {
  position: relative; z-index: 1; font-size: 16rpx; color: #3b82f6; font-weight: 700; margin-top: 2rpx;
}

/* AI评分环（大版） */
.ai-score-ring-big {
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  width: 140rpx; height: 140rpx; border-radius: 50%;
  background: conic-gradient(#3b82f6 0%, #06b6d4 60%, rgba(255,255,255,.06) 60%);
  box-shadow: 0 0 32px rgba(59,130,246,.55), inset 0 0 12px rgba(59,130,246,.15);
  position: relative;
  animation: ring-pulse 3s ease-in-out infinite;
}
@keyframes ring-pulse {
  0%, 100% { box-shadow: 0 0 28px rgba(59,130,246,.5), inset 0 0 12px rgba(59,130,246,.1); }
  50%       { box-shadow: 0 0 48px rgba(59,130,246,.85), inset 0 0 20px rgba(59,130,246,.25); }
}
.ai-score-ring-big::before {
  content: ''; position: absolute; width: 108rpx; height: 108rpx;
  border-radius: 50%; background: #07090f;
}
/* 有信号时颜色变化 */
.ai-score-ring-big.signal-long {
  background: conic-gradient(#f87171 0%, #fb923c 70%, rgba(255,255,255,.06) 70%);
  box-shadow: 0 0 40px rgba(248,113,113,.6);
  animation: ring-pulse-long 2s ease-in-out infinite;
}
@keyframes ring-pulse-long {
  0%, 100% { box-shadow: 0 0 32px rgba(248,113,113,.5); }
  50%       { box-shadow: 0 0 60px rgba(248,113,113,.9); }
}
.ai-score-ring-big.signal-short {
  background: conic-gradient(#34d399 0%, #06b6d4 70%, rgba(255,255,255,.06) 70%);
  box-shadow: 0 0 40px rgba(52,211,153,.6);
  animation: ring-pulse-short 2s ease-in-out infinite;
}
@keyframes ring-pulse-short {
  0%, 100% { box-shadow: 0 0 32px rgba(52,211,153,.5); }
  50%       { box-shadow: 0 0 60px rgba(52,211,153,.9); }
}
/* 圆圈内图标 */
.ai-ring-icon {
  position: relative; z-index: 1; font-size: 28rpx; line-height: 1; margin-bottom: 2rpx;
}
.ai-ring-num-big {
  position: relative; z-index: 1; font-size: 46rpx; font-weight: 900;
  color: #93c5fd; line-height: 1;
}
.ai-ring-den-big {
  position: relative; z-index: 1; font-size: 18rpx; color: #64748b; margin-top: -2rpx;
}
.ai-ring-label-big {
  position: relative; z-index: 1; font-size: 20rpx; color: #3b82f6; font-weight: 700; margin-top: 3rpx;
}

/* ─────────── 动态分段进度条 ─────────── */
.ai-prog-track {
  position: relative; height: 14rpx;
  background: rgba(255,255,255,.06);
  border-radius: 14rpx; overflow: visible;
  margin: 6rpx 0 2rpx;
}
.ai-prog-fill {
  height: 100%; border-radius: 14rpx; position: relative;
  background: linear-gradient(90deg, #3b82f6, #06b6d4);
  transition: width .8s cubic-bezier(.34,1.56,.64,1);
  overflow: hidden;
}
.ai-prog-fill.buy, .ai-prog-fill.signal-long {
  background: linear-gradient(90deg, #f87171, #fb923c);
}
.ai-prog-fill.short_s, .ai-prog-fill.signal-short {
  background: linear-gradient(90deg, #34d399, #06b6d4);
}
.ai-prog-fill.ok   { background: linear-gradient(90deg, #60a5fa, #818cf8); }
.ai-prog-fill.watch{ background: linear-gradient(90deg, #fbbf24, #f59e0b); }
/* 进度条内光晕扫光 */
.ai-prog-glow {
  position: absolute; top: 0; right: -20rpx;
  width: 40rpx; height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,.6), transparent);
  animation: prog-sweep 2s ease-in-out infinite;
}
@keyframes prog-sweep {
  0%   { opacity: 0; transform: translateX(-60rpx); }
  40%  { opacity: 1; }
  100% { opacity: 0; transform: translateX(20rpx); }
}
/* 分段刻度线 */
.ai-prog-seg {
  position: absolute; top: -3rpx; width: 2rpx; height: 20rpx;
  background: rgba(255,255,255,.12); border-radius: 2rpx;
  transition: background .4s, box-shadow .4s;
}
.ai-prog-seg.s1 { left: 25%; }
.ai-prog-seg.s2 { left: 50%; }
.ai-prog-seg.s3 { left: 75%; }
.ai-prog-seg.s4 { left: 100%; }
.ai-prog-seg.lit {
  background: rgba(255,255,255,.7);
  box-shadow: 0 0 8px rgba(255,255,255,.8);
}
/* 刻度标签 */
.ai-prog-labels {
  display: flex; justify-content: space-between;
  padding: 0 2rpx; margin-bottom: 4rpx;
}
.ai-prog-l { font-size: 17rpx; color: #334155; }



/* ─────────── 周期切换（顶部大行，内嵌K线图顶部旧样式保留兼容） ─────────── */
.period-bar-top {
  display: flex; white-space: nowrap;
  width: 100%; padding: 8rpx 18rpx 10rpx;
  background: rgba(7,9,15,.6);
  border-bottom: 1rpx solid rgba(255,255,255,.06);
}
.period-btn-top {
  display: inline-block; flex-shrink: 0;
  background: rgba(255,255,255,.05); border: 1.5rpx solid rgba(255,255,255,.1);
  border-radius: 16rpx; padding: 8rpx 22rpx;
  font-size: 26rpx; font-weight: 700; color: #64748b;
  margin-right: 10rpx;
  transition: all .2s cubic-bezier(.34,1.56,.64,1);
}
.period-btn-top.active {
  background: linear-gradient(135deg, rgba(59,130,246,.3), rgba(6,182,212,.22));
  border-color: #3b82f6; color: #fff; font-weight: 900;
  box-shadow: 0 0 14px rgba(59,130,246,.4);
  transform: scale(1.07);
}
.period-more-top {
  display: inline-block; flex-shrink: 0;
  background: rgba(251,191,36,.07); border: 1.5rpx solid rgba(251,191,36,.2);
  border-radius: 16rpx; padding: 8rpx 18rpx;
  font-size: 22rpx; color: #fbbf24; font-weight: 700;
}
/* 旧inline样式保留（kline-header内，现在kline-header已不含周期切换，可能不再用） */
.period-bar-inline {
  display: flex; white-space: nowrap;
  width: 100%; margin-top: 10rpx;
}
.period-btn-inline {
  display: inline-block; flex-shrink: 0;
  background: rgba(255,255,255,.04); border: 1.5rpx solid rgba(255,255,255,.08);
  border-radius: 16rpx; padding: 7rpx 22rpx;
  font-size: 26rpx; font-weight: 700; color: #64748b;
  margin-right: 8rpx;
  transition: all .2s cubic-bezier(.34,1.56,.64,1);
}
.period-btn-inline.active {
  background: linear-gradient(135deg, rgba(59,130,246,.28), rgba(6,182,212,.2));
  border-color: #3b82f6; color: #fff; font-weight: 900;
  box-shadow: 0 0 12px rgba(59,130,246,.35);
  transform: scale(1.06);
}
.period-more-inline {
  display: inline-block; flex-shrink: 0;
  background: rgba(251,191,36,.07); border: 1.5rpx solid rgba(251,191,36,.2);
  border-radius: 16rpx; padding: 7rpx 18rpx;
  font-size: 22rpx; color: #fbbf24; font-weight: 700;
}

/* ─────────── 大趋势判断卡（升级版） ─────────── */
.frog-trend-card {
  margin: 14rpx 18rpx 0;
  background: rgba(10,16,28,.88);
  border: 1.5rpx solid rgba(59,130,246,.22);
  border-radius: 24rpx;
  padding: 18rpx 20rpx;
  display: flex; align-items: center; gap: 16rpx;
  position: relative; overflow: hidden;
  backdrop-filter: blur(10px);
}
.ftc-glow {
  position: absolute; top: -40rpx; left: -30rpx;
  width: 220rpx; height: 220rpx; border-radius: 50%;
  opacity: .12; pointer-events: none;
  background: #3b82f6;
}
.ftc-glow.bull     { background: #f87171; opacity: .2; }
.ftc-glow.bear     { background: #34d399; opacity: .2; }
.ftc-glow.bull_w   { background: #fbbf24; opacity: .15; }
.ftc-glow.bear_w   { background: #94a3b8; opacity: .1; }
.ftc-glow.sideways { background: #60a5fa; opacity: .12; }
.ftc-icon-wrap {
  width: 78rpx; height: 78rpx; border-radius: 20rpx; flex-shrink: 0;
  background: rgba(59,130,246,.1);
  border: 1.5rpx solid rgba(59,130,246,.28);
  display: flex; align-items: center; justify-content: center;
  animation: ftc-icon-pulse 3s ease-in-out infinite;
}
.ftc-icon-wrap.bull   { background: rgba(248,113,113,.12); border-color: rgba(248,113,113,.38); box-shadow: 0 0 20px rgba(248,113,113,.2); }
.ftc-icon-wrap.bear   { background: rgba(52,211,153,.12);  border-color: rgba(52,211,153,.38);  box-shadow: 0 0 20px rgba(52,211,153,.2); }
.ftc-icon-wrap.bull_w { background: rgba(251,191,36,.1);   border-color: rgba(251,191,36,.3); }
.ftc-icon-wrap.bear_w { background: rgba(148,163,184,.08); border-color: rgba(148,163,184,.2); }
.ftc-icon-wrap.sideways { background: rgba(96,165,250,.08); border-color: rgba(96,165,250,.25); }
@keyframes ftc-icon-pulse {
  0%, 100% { transform: scale(1); }
  50%       { transform: scale(1.07); }
}
.ftc-icon-big { font-size: 44rpx; line-height: 1; position: relative; z-index: 1; }
.ftc-body { flex: 1; display: flex; flex-direction: column; gap: 4rpx; }
.ftc-label-trend { font-size: 20rpx; color: #475569; font-weight: 700; letter-spacing: 1rpx; }
.ftc-trend-big { font-size: 36rpx; font-weight: 900; color: #e2e8f0; }
.ftc-trend-big.bull     { color: #f87171; }
.ftc-trend-big.bear     { color: #34d399; }
.ftc-trend-big.bull_w   { color: #fbbf24; }
.ftc-trend-big.bear_w   { color: #94a3b8; }
.ftc-trend-big.sideways { color: #60a5fa; }
.ftc-period { font-size: 19rpx; color: rgba(96,165,250,.55); }
.ftc-badge {
  display: flex; align-items: center;
  padding: 10rpx 22rpx; border-radius: 24rpx;
  border: 1.5rpx solid rgba(255,255,255,.1); flex-shrink: 0;
}
.ftc-badge.bull     { background: rgba(248,113,113,.15); border-color: rgba(248,113,113,.4); }
.ftc-badge.bull_w   { background: rgba(251,191,36,.12);  border-color: rgba(251,191,36,.35); }
.ftc-badge.bear     { background: rgba(52,211,153,.15);  border-color: rgba(52,211,153,.4); }
.ftc-badge.bear_w   { background: rgba(148,163,184,.1);  border-color: rgba(148,163,184,.25); }
.ftc-badge.sideways { background: rgba(96,165,250,.1);   border-color: rgba(96,165,250,.28); }
.ftc-badge-txt { font-size: 24rpx; font-weight: 900; color: #e2e8f0; }
.ftc-badge.bull     .ftc-badge-txt { color: #f87171; }
.ftc-badge.bull_w   .ftc-badge-txt { color: #fbbf24; }
.ftc-badge.bear     .ftc-badge-txt { color: #34d399; }
.ftc-badge.bear_w   .ftc-badge-txt { color: #94a3b8; }
.ftc-badge.sideways .ftc-badge-txt { color: #60a5fa; }

/* ─────────── 等待信号：动态表情脸（笑脸/哭脸） ─────────── */
.wait-face-wrap {
  display: flex; align-items: center; justify-content: center;
  width: 88rpx; height: 88rpx;
}

/* 容器：涟漪背景 */
.wait-face-container {
  position: relative;
  display: flex; align-items: center; justify-content: center;
  width: 88rpx; height: 88rpx;
}

/* 笑脸模式：黄金大饼色 */
.bull-mode .face-circle {
  width: 72rpx; height: 72rpx; border-radius: 50%;
  background: linear-gradient(145deg, #ffd700 0%, #ffb300 60%, #ff9f0a 100%);
  box-shadow: 0 0 18px rgba(255,180,0,.7), 0 0 40px rgba(255,140,0,.35);
  position: relative; z-index: 2;
  animation: face-bounce 2s ease-in-out infinite;
  display: flex; align-items: center; justify-content: center;
  overflow: hidden;
}
/* 哭脸模式：淡蓝小号 */
.bear-mode .face-circle {
  width: 58rpx; height: 58rpx; border-radius: 50%;
  background: linear-gradient(145deg, #60a5fa 0%, #3b82f6 60%, #1d4ed8 100%);
  box-shadow: 0 0 14px rgba(59,130,246,.6);
  position: relative; z-index: 2;
  animation: face-sad-shake 3s ease-in-out infinite;
  display: flex; align-items: center; justify-content: center;
  overflow: hidden;
}

@keyframes face-bounce {
  0%,100% { transform: scale(1) translateY(0); }
  30%      { transform: scale(1.12) translateY(-4rpx); }
  60%      { transform: scale(0.96) translateY(2rpx); }
}
@keyframes face-sad-shake {
  0%,100% { transform: scale(1) rotate(0deg); }
  20%      { transform: scale(1.03) rotate(-4deg); }
  40%      { transform: scale(1.03) rotate(4deg); }
  60%      { transform: scale(1) rotate(-2deg); }
  80%      { transform: scale(1) rotate(2deg); }
}

/* 眼睛 */
.face-eyes {
  position: absolute; top: 28%; left: 0; right: 0;
  display: flex; justify-content: center; gap: 14rpx;
}
.bull-mode .face-eyes { gap: 18rpx; top: 26%; }
.bear-mode .face-eyes { gap: 14rpx; top: 28%; }

.face-eye {
  width: 10rpx; height: 10rpx; border-radius: 50%; background: #5c3800;
}
.bear-mode .face-eye {
  width: 8rpx; height: 8rpx; background: #fff;
  animation: eye-cry 2s ease-in-out infinite;
}
@keyframes eye-cry {
  0%,80%,100% { transform: scaleY(1); }
  85%  { transform: scaleY(.2); }
}

/* 嘴巴 */
.face-mouth {
  position: absolute; bottom: 22%; left: 50%;
  transform: translateX(-50%);
}
.smile-mouth {
  width: 32rpx; height: 16rpx;
  border-bottom: 4rpx solid #5c3800;
  border-left: 4rpx solid transparent;
  border-right: 4rpx solid transparent;
  border-radius: 0 0 32rpx 32rpx;
}
.sad-mouth {
  width: 22rpx; height: 12rpx;
  border-top: 3rpx solid rgba(255,255,255,.8);
  border-left: 3rpx solid transparent;
  border-right: 3rpx solid transparent;
  border-radius: 32rpx 32rpx 0 0;
  bottom: 18%;
}

/* 腮红（笑脸专属） */
.face-cheek {
  position: absolute; top: 52%; width: 14rpx; height: 8rpx;
  border-radius: 50%; background: rgba(255,100,100,.4);
}
.left-cheek  { left: 10%; }
.right-cheek { right: 10%; }

/* 眼泪（哭脸专属） */
.face-tear {
  position: absolute; top: 44%;
  width: 5rpx; height: 10rpx; border-radius: 0 0 5rpx 5rpx;
  background: rgba(147,197,253,.8);
  animation: tear-fall 2s ease-in-out infinite;
}
.left-tear  { left: 27%; animation-delay: 0s; }
.right-tear { right: 27%; animation-delay: .7s; }
@keyframes tear-fall {
  0%,60%  { transform: translateY(0); opacity: 0; }
  70%     { opacity: 1; }
  100%    { transform: translateY(14rpx); opacity: 0; }
}

/* 涟漪波纹 */
.wait-face-ripple {
  position: absolute; border-radius: 50%; pointer-events: none;
}
.bull-ripple {
  border: 2rpx solid rgba(255,180,0,.5);
  animation: ripple-bull 2.5s ease-out infinite;
}
.bear-ripple {
  border: 2rpx solid rgba(59,130,246,.4);
  animation: ripple-bear 2.5s ease-out infinite;
}
.wait-face-ripple.r1 { width: 80rpx; height: 80rpx; animation-delay: 0s; }
.wait-face-ripple.r2 { width: 80rpx; height: 80rpx; animation-delay: 1.2s; }

@keyframes ripple-bull {
  0%   { transform: scale(.8);  opacity: .8; }
  100% { transform: scale(1.6); opacity: 0; }
}
@keyframes ripple-bear {
  0%   { transform: scale(.7);  opacity: .7; }
  100% { transform: scale(1.4); opacity: 0; }
}

/* ─────────── 旧雷达扫描动画（保留兼容） ─────────── */
.radar-scan-wrap {
  width: 90rpx; height: 90rpx; position: relative;
  display: flex; align-items: center; justify-content: center;
}
.radar-ring {
  position: absolute; border-radius: 50%;
  border: 1.5rpx solid rgba(96,165,250,.3);
  animation: radar-expand 2.4s ease-out infinite;
}
.radar-ring.r1 { width: 90rpx; height: 90rpx; animation-delay: 0s; }
.radar-ring.r2 { width: 62rpx; height: 62rpx; animation-delay: .7s; }
.radar-ring.r3 { width: 36rpx; height: 36rpx; animation-delay: 1.4s; }
@keyframes radar-expand {
  0%   { opacity: .8; transform: scale(.55); }
  70%  { opacity: .2; }
  100% { opacity: 0;  transform: scale(1.15); }
}
.radar-sweep {
  position: absolute; width: 46rpx; height: 46rpx; border-radius: 50%;
  background: conic-gradient(rgba(96,165,250,.6) 0deg, transparent 65deg);
  animation: radar-rotate 1.8s linear infinite;
  transform-origin: center;
}
@keyframes radar-rotate {
  from { transform: rotate(0deg); }
  to   { transform: rotate(360deg); }
}
.radar-center-icon { position: relative; z-index: 2; font-size: 28rpx; }

.ftc-detail-row {
  margin: 0 18rpx;
  background: rgba(7,9,15,.9);
  border: 1.5rpx solid rgba(59,130,246,.15);
  border-top: none;
  border-radius: 0 0 18rpx 18rpx;
  display: flex;
  padding: 12rpx 0 14rpx;
}
.ftc-detail-item {
  flex: 1; text-align: center;
  border-right: 1rpx solid rgba(255,255,255,.06);
}
.ftc-detail-item:last-child { border-right: none; }
.ftc-d-label { display: block; font-size: 18rpx; color: #475569; margin-bottom: 4rpx; }
.ftc-d-val   { display: block; font-size: 24rpx; font-weight: 800; color: #94a3b8; }
.ftc-d-val.red   { color: #f87171; }
.ftc-d-val.green { color: #34d399; }
.ftc-d-val.gray  { color: #475569; }



/* ─────────── K线图顶部区域 ─────────── */
.kline-header {
  margin: 16rpx 18rpx 0;
  background: rgba(59,130,246,.04);
  border: 1rpx solid rgba(59,130,246,.15);
  border-radius: 20rpx 20rpx 0 0;
  border-bottom: none;
  padding: 10rpx 14rpx 8rpx;
}

/* Pill胶囊周期切换 */
.kline-period-pills {
  display: flex; flex-direction: row; flex-wrap: wrap;
  gap: 8rpx; padding-bottom: 10rpx;
}
.kpill {
  display: inline-flex; align-items: center; justify-content: center;
  background: rgba(255,255,255,.05);
  border: 1.5rpx solid rgba(255,255,255,.1);
  border-radius: 999rpx;
  padding: 6rpx 22rpx;
  font-size: 24rpx; color: #64748b; font-weight: 600;
  transition: all .2s cubic-bezier(.34,1.56,.64,1);
  flex-shrink: 0;
}
.kpill:active { transform: scale(.93); }
.kpill-active {
  background: linear-gradient(135deg, rgba(59,130,246,.35), rgba(6,182,212,.25));
  border-color: #3b82f6; color: #e0f2fe; font-weight: 900;
  box-shadow: 0 0 10px rgba(59,130,246,.4);
  transform: scale(1.06);
}
.kpill-more {
  color: #fbbf24; border-color: rgba(251,191,36,.3);
  background: rgba(251,191,36,.06); font-size: 22rpx;
}

.kline-title-row {
  display: flex; align-items: center; justify-content: space-between;
}
.kline-title-txt { font-size: 26rpx; font-weight: 800; color: #f1f5f9; }

/* ─────────── 周期切换 ─────────── */
.period-bar {
  display: flex; white-space: nowrap; padding: 0 0 12rpx; gap: 8rpx;
  width: 100%;
}
.period-btn {
  display: inline-block; flex-shrink: 0;
  background: rgba(255,255,255,.04); border: 1rpx solid rgba(255,255,255,.08);
  border-radius: 20rpx; padding: 8rpx 20rpx; font-size: 24rpx; color: #64748b;
  transition: all .2s cubic-bezier(.34,1.56,.64,1);
}
.period-btn.active {
  background: linear-gradient(135deg, rgba(59,130,246,.28), rgba(6,182,212,.2));
  border-color: #3b82f6; color: #93c5fd; font-weight: 800;
  box-shadow: 0 0 14px rgba(59,130,246,.35);
  transform: scale(1.05);
}
.period-more-btn {
  display: inline-block; flex-shrink: 0;
  background: rgba(251,191,36,.08); border: 1rpx solid rgba(251,191,36,.25);
  border-radius: 20rpx; padding: 8rpx 18rpx; font-size: 22rpx; color: #fbbf24;
  font-weight: 700;
}

/* ─────────── 决策大卡 ─────────── */
.decision-card {
  margin: 0 18rpx 18rpx; border-radius: 28rpx; padding: 28rpx 22rpx 20rpx;
  border: 1rpx solid transparent; position: relative; overflow: hidden;
  backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);
}
.wait    { background: rgba(15,20,35,.9);           border-color: rgba(100,116,139,.2); }
.buy     { background: rgba(248,113,113,.07);        border-color: rgba(248,113,113,.4); }
.short_s { background: rgba(52,211,153,.07);         border-color: rgba(52,211,153,.4); }
.ok      { background: rgba(251,191,36,.07);         border-color: rgba(251,191,36,.35); }
.watch   { background: rgba(251,146,60,.07);         border-color: rgba(251,146,60,.3); }
.no      { background: rgba(100,116,139,.06);        border-color: rgba(100,116,139,.2); }

.decision-glow {
  position: absolute; top: -50rpx; right: -50rpx;
  width: 220rpx; height: 220rpx; border-radius: 50%;
  opacity: 0.1; pointer-events: none;
}
.decision-glow.buy     { background: radial-gradient(circle, #f87171, transparent); }
.decision-glow.short_s { background: radial-gradient(circle, #34d399, transparent); }
.decision-glow.ok      { background: radial-gradient(circle, #fbbf24, transparent); }
.decision-glow.watch   { background: radial-gradient(circle, #fb923c, transparent); }
.decision-glow.wait,.decision-glow.no { background: radial-gradient(circle, #3b82f6, transparent); }

/* AI角标 */
.ai-corner-tag {
  position: absolute; top: 0; left: 0;
  background: linear-gradient(90deg, #1d4ed8, #0891b2);
  padding: 5rpx 18rpx 5rpx 16rpx; border-radius: 0 0 16rpx 0;
  font-size: 18rpx; color: rgba(255,255,255,.9); font-weight: 700;
}

.decision-top { display: flex; align-items: center; gap: 18rpx; position: relative; z-index: 1; margin-top: 8rpx; }

.decision-face-wrap {
  width: 88rpx; height: 88rpx; border-radius: 50%; flex-shrink: 0;
  display: flex; align-items: center; justify-content: center;
  background: rgba(255,255,255,.05); border: 2rpx solid rgba(255,255,255,.1);
}
.decision-face-wrap.buy     { background: rgba(248,113,113,.12); border-color: rgba(248,113,113,.4); }
.decision-face-wrap.short_s { background: rgba(52,211,153,.12);  border-color: rgba(52,211,153,.4); }
.decision-face-wrap.ok      { background: rgba(251,191,36,.12);  border-color: rgba(251,191,36,.4); }
.decision-face-wrap.watch   { background: rgba(251,146,60,.12);  border-color: rgba(251,146,60,.4); }
.decision-face { font-size: 46rpx; }

.decision-text { flex: 1; }
.decision-verdict { display: block; font-size: 36rpx; font-weight: 800; color: #f1f5f9; }
.decision-sub     { display: block; font-size: 22rpx; color: #94a3b8; margin-top: 4rpx; line-height: 1.5; }
.decision-meta { display: flex; gap: 8rpx; flex-wrap: wrap; margin-top: 10rpx; }
.meta-tag {
  font-size: 18rpx; padding: 4rpx 12rpx; border-radius: 12rpx;
  background: rgba(255,255,255,.07); color: #94a3b8; font-weight: 600;
}
.meta-tag.long  { background: rgba(248,113,113,.18); color: #f87171; }
.meta-tag.short { background: rgba(52,211,153,.18);  color: #34d399; }
.meta-tag.accent { background: rgba(251,191,36,.2);  color: #fbbf24; }

.score-circle {
  display: flex; flex-direction: column; align-items: center; flex-shrink: 0;
  width: 72rpx; height: 72rpx; border-radius: 50%;
  background: rgba(255,255,255,.05); border: 2rpx solid rgba(59,130,246,.4);
  justify-content: center;
}
.score-circle.buy     { border-color: rgba(248,113,113,.6); }
.score-circle.short_s { border-color: rgba(52,211,153,.6); }
.score-circle.ok      { border-color: rgba(251,191,36,.6); }
.score-num { font-size: 36rpx; font-weight: 900; color: #fbbf24; line-height: 1; }
.score-den { font-size: 16rpx; color: #64748b; margin-top: -2rpx; }

.score-bar-wrap {
  margin: 18rpx 0 10rpx; height: 6rpx; background: rgba(255,255,255,.07);
  border-radius: 3rpx; overflow: hidden; position: relative; z-index: 1;
}
.score-bar-fill { height: 100%; border-radius: 3rpx; transition: width .6s cubic-bezier(.34,1.56,.64,1); }
.score-bar-fill.buy     { background: linear-gradient(90deg, #f87171, #fca5a5); }
.score-bar-fill.short_s { background: linear-gradient(90deg, #34d399, #6ee7b7); }
.score-bar-fill.ok      { background: linear-gradient(90deg, #60a5fa, #fbbf24); }
.score-bar-fill.watch   { background: linear-gradient(90deg, #fb923c, #fbbf24); }
.score-bar-fill.wait,.score-bar-fill.no { background: linear-gradient(90deg, #334155, #64748b); }

.decision-bottom { display: flex; justify-content: space-between; align-items: center; position: relative; z-index: 1; }
.score-stars { font-size: 26rpx; color: #fbbf24; letter-spacing: 3rpx; }
.score-label-wrap { display: flex; align-items: center; gap: 12rpx; }
.score-label { font-size: 22rpx; padding: 4rpx 16rpx; border-radius: 20rpx; font-weight: 700; }
.score-label.buy     { background: rgba(248,113,113,.2);  color: #f87171; }
.score-label.short_s { background: rgba(52,211,153,.2);   color: #34d399; }
.score-label.ok      { background: rgba(251,191,36,.2);   color: #fbbf24; }
.score-label.watch   { background: rgba(251,146,60,.2);   color: #fb923c; }
.score-label.no,.score-label.wait { background: rgba(100,116,139,.15); color: #64748b; }
.update-time { font-size: 18rpx; color: #334155; }

/* ─────────── 标题通用 ─────────── */
.section-title {
  display: flex; justify-content: space-between; align-items: center;
  margin: 20rpx 22rpx 12rpx; font-size: 28rpx; font-weight: 800; color: #f1f5f9;
}
.section-title-plain {
  margin: 18rpx 22rpx 12rpx; font-size: 28rpx; font-weight: 800; color: #f1f5f9;
  display: flex; align-items: center; justify-content: space-between;
}
.section-sub { font-size: 20rpx; color: #475569; font-weight: 400; }
.dir-tag { font-size: 22rpx; padding: 4rpx 18rpx; border-radius: 20rpx; font-weight: 700; }
.dir-tag.long  { background: rgba(248,113,113,.2); color: #f87171; }
.dir-tag.short { background: rgba(52,211,153,.2);  color: #34d399; }

/* ─────────── 信号详情 ─────────── */
.signal-detail {
  margin: 0 18rpx; background: rgba(15,20,35,.95); border-radius: 22rpx;
  border: 1rpx solid #1e293b; overflow: hidden; padding: 18rpx 18rpx 0;
}
.signal-detail.long  { border-color: rgba(248,113,113,.3); }
.signal-detail.short { border-color: rgba(52,211,153,.3); }
.detail-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12rpx; padding-bottom: 14rpx; }
.detail-cell { background: rgba(255,255,255,.03); border-radius: 14rpx; padding: 14rpx; }
.dc-label { display: block; font-size: 20rpx; color: #64748b; margin-bottom: 6rpx; }
.dc-val   { display: block; font-size: 30rpx; font-weight: 800; color: #f1f5f9; }
.dc-val.accent { color: #fbbf24; }
.dc-val.loss   { color: #fb923c; }

/* ─────────── 止盈止损常驻卡 ─────────── */
.tp-card {
  margin: 0 18rpx 20rpx;
  border-radius: 24rpx;
  overflow: hidden;
  border: 1rpx solid rgba(255,107,107,.25);
  background: rgba(15,25,41,.8);
}
.tp-card.long  { border-color: rgba(248,113,113,.35); }
.tp-card.short { border-color: rgba(52,211,153,.35); }
.tp-card.ref   { border-color: rgba(96,165,250,.25); }

.tp-card-header {
  padding: 18rpx 22rpx 14rpx;
  background: rgba(255,255,255,.03);
  border-bottom: 1rpx solid rgba(255,255,255,.06);
}
.tp-card-title-row {
  display: flex; align-items: center; gap: 10rpx; margin-bottom: 8rpx;
}
.tp-card-icon { font-size: 28rpx; }
.tp-card-title {
  font-size: 26rpx; font-weight: 800; color: #e2e8f0; flex: 1;
}
.tp-card-badge {
  padding: 4rpx 14rpx; border-radius: 20rpx; font-size: 20rpx; font-weight: 700;
}
.tp-card-badge.signal {
  background: rgba(248,113,113,.15); color: #fb923c; border: 1rpx solid rgba(248,113,113,.3);
}
.tp-card-badge.ref {
  background: rgba(96,165,250,.12); color: #60a5fa; border: 1rpx solid rgba(96,165,250,.25);
}
.tp-meta-row { display: flex; align-items: center; gap: 8rpx; flex-wrap: wrap; }
.tp-meta-item { font-size: 22rpx; color: #94a3b8; }
.tp-meta-item.loss   { color: #fb923c; }
.tp-meta-item.accent { color: #34d399; }
.tp-meta-item.muted  { color: #475569; }
.tp-meta-sep { font-size: 20rpx; color: #334155; }

.tp-levels {
  display: flex; border-top: 1rpx solid rgba(255,255,255,.05);
}
.tp-level-item {
  flex: 1; padding: 16rpx 0 14rpx; text-align: center;
  border-right: 1rpx solid rgba(255,255,255,.05);
}
.tp-level-item:last-child { border-right: none; }
.tp-level-item.sl { background: rgba(251,146,60,.04); }
.tp-level-item.t1 { background: rgba(52,211,153,.03); }
.tp-level-item.t2 { background: rgba(52,211,153,.05); }
.tp-level-item.t3 { background: rgba(52,211,153,.08); }

.tp-level-label {
  display: block; font-size: 18rpx; color: #64748b; margin-bottom: 4rpx;
}
.tp-level-val {
  display: block; font-size: 26rpx; font-weight: 900; margin-bottom: 3rpx;
}
