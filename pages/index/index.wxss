/* ╔══════════════════════════════════════════════
   ║  大饼K线雷达  v7.1 · 黑金深邃风
   ║  背景：深邃黑金星空  配色：金橙+青蓝
   ╚══════════════════════════════════════════════ */

/* ── 全局 ── */
page {
  background: #090b10;
  background-image:
    radial-gradient(ellipse at 15% 20%, rgba(30,50,90,.5) 0%, transparent 55%),
    radial-gradient(ellipse at 85% 70%, rgba(20,40,70,.4) 0%, transparent 55%),
    radial-gradient(ellipse at 50% 95%, rgba(40,30,20,.3) 0%, transparent 50%);
  color: #e8eaf6;
  font-size: 28rpx;
  min-height: 100vh;
}

/* ── 玻璃卡片通用 ── */
.glass {
  background: rgba(255,255,255,.06);
  backdrop-filter: blur(12px);
  border: 1rpx solid rgba(255,255,255,.12);
  border-radius: 28rpx;
}

/* ══════════════════════════════════════════════
   导航栏
══════════════════════════════════════════════ */
@keyframes pulse-dot  { 0%,100%{box-shadow:0 0 6px #4ade80} 50%{box-shadow:0 0 16px #4ade80,0 0 28px rgba(74,222,128,.5)} }
@keyframes blink      { 0%,100%{opacity:1} 50%{opacity:.2} }
@keyframes float-up   { 0%{transform:translateY(0)} 50%{transform:translateY(-5rpx)} 100%{transform:translateY(0)} }
@keyframes radar-ring { 0%{transform:scale(.7);opacity:.8} 100%{transform:scale(1.8);opacity:0} }
@keyframes spin-slow  { from{transform:rotate(0deg)} to{transform:rotate(360deg)} }

.navbar {
  display: flex; justify-content: space-between; align-items: center;
  padding: 26rpx 28rpx 22rpx;
  background: linear-gradient(180deg, rgba(8,12,24,.98) 0%, rgba(10,15,28,.94) 100%);
  border-bottom: 1rpx solid rgba(96,165,250,.15);
  position: sticky; top: 0; z-index: 99;
  box-shadow: 0 4rpx 30rpx rgba(0,0,0,.5);
}
.navbar-left  { display: flex; align-items: center; gap: 18rpx; flex: 1; }
.navbar-right { display: flex; align-items: center; gap: 16rpx; flex-shrink: 0; }

/* 雷达图标 */
.nav-radar-icon {
  position: relative; width: 64rpx; height: 64rpx;
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}
.nav-radar-emoji { font-size: 44rpx; position: relative; z-index: 2; }
.nav-radar-ring {
  position: absolute; top: 50%; left: 50%;
  transform: translate(-50%,-50%) scale(.7);
  width: 64rpx; height: 64rpx; border-radius: 50%;
  border: 2rpx solid rgba(96,165,250,.6);
  animation: radar-ring 2s ease-out infinite;
}

/* 标题块 */
.nav-title-block { display: flex; flex-direction: column; gap: 4rpx; }
.nav-title {
  font-size: 36rpx; font-weight: 900; letter-spacing: 2rpx;
  background: linear-gradient(135deg, #fbbf24 0%, #60a5fa 55%, #34d399 100%);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  background-clip: text;
}
.nav-sub {
  font-size: 19rpx; color: rgba(255,255,255,.32);
  letter-spacing: .5rpx;
}

/* 绿点 */
.live-dot {
  width: 16rpx; height: 16rpx; border-radius: 50%;
  background: #4ade80;
  box-shadow: 0 0 0 3rpx rgba(74,222,128,.2), 0 0 10px #4ade80;
  flex-shrink: 0; animation: pulse-dot 2s ease-in-out infinite;
}
.live-dot.loading {
  background: #fb923c;
  box-shadow: 0 0 8px #fb923c;
  animation: blink 0.7s infinite;
}

/* 刷新按钮 */
.nav-refresh-btn {
  display: flex; flex-direction: column; align-items: center; gap: 2rpx;
  background: linear-gradient(135deg, rgba(96,165,250,.15), rgba(52,211,153,.1));
  border: 1rpx solid rgba(96,165,250,.3);
  padding: 8rpx 22rpx; border-radius: 28rpx;
  transition: all .2s;
}
.nav-refresh-text  { font-size: 26rpx; line-height: 1; }
.nav-refresh-label { font-size: 17rpx; color: #7dd3fc; font-weight: 600; }

/* ══════════════════════════════════════════════
   价格大头
══════════════════════════════════════════════ */
.price-hero {
  display: flex; justify-content: space-between; align-items: center;
  padding: 22rpx 30rpx 16rpx;
  border-bottom: 1rpx solid rgba(255,255,255,.05);
}
.price-hero-left { display: flex; flex-direction: column; gap: 12rpx; }
.price-hero-right-blank { width: 40rpx; }

.price-main {
  font-size: 64rpx; font-weight: 900; letter-spacing: 2rpx;
  text-shadow: 0 2px 20px rgba(255,255,255,.08);
  color: #f1f5f9;
}
.price-main.up   { color: #fb7185; text-shadow: 0 0 28rpx rgba(251,113,133,.5); }
.price-main.down { color: #34d399; text-shadow: 0 0 28rpx rgba(52,211,153,.5); }
.price-badges { display: flex; gap: 10rpx; flex-wrap: wrap; align-items: center; }
.price-badge {
  font-size: 21rpx; padding: 4rpx 14rpx; border-radius: 20rpx; font-weight: 800;
}
.price-badge.up   { background: rgba(251,113,133,.18); color: #fb7185; border: 1rpx solid rgba(251,113,133,.35); }
.price-badge.down { background: rgba(52,211,153,.18);  color: #34d399; border: 1rpx solid rgba(52,211,153,.35); }
.price-badge-plain {
  font-size: 20rpx; padding: 4rpx 14rpx; border-radius: 20rpx;
  background: rgba(255,255,255,.07); color: rgba(255,255,255,.45);
  border: 1rpx solid rgba(255,255,255,.1);
}

/* ══════════════════════════════════════════════
   决策大卡  ✦  核心区域
══════════════════════════════════════════════ */
.decision-card {
  margin: 10rpx 20rpx 22rpx;
  border-radius: 36rpx; padding: 34rpx 26rpx 24rpx;
  border: 1.5rpx solid rgba(255,255,255,.1);
  position: relative; overflow: hidden;
  background: rgba(255,255,255,.05);
  backdrop-filter: blur(18px);
  box-shadow: 0 10rpx 48rpx rgba(0,0,0,.4);
}
/* 状态主题 */
.wait    { border-color: rgba(129,140,248,.25); }
.buy     { border-color: rgba(251,113,133,.45); background: rgba(251,113,133,.06); box-shadow: 0 8rpx 40rpx rgba(251,113,133,.12); }
.short_s { border-color: rgba(52,211,153,.45);  background: rgba(52,211,153,.06);  box-shadow: 0 8rpx 40rpx rgba(52,211,153,.12); }
.ok      { border-color: rgba(251,191,36,.4);   background: rgba(251,191,36,.05);  box-shadow: 0 8rpx 40rpx rgba(251,191,36,.1); }
.watch   { border-color: rgba(251,146,60,.35);  background: rgba(251,146,60,.05); }
.no      { border-color: rgba(148,163,184,.2); }

/* 背景光晕 */
.decision-glow {
  position: absolute; top: -60rpx; right: -60rpx;
  width: 260rpx; height: 260rpx; border-radius: 50%;
  opacity: .15; pointer-events: none;
}
.decision-glow.buy     { background: radial-gradient(circle, #fb7185, transparent); }
.decision-glow.short_s { background: radial-gradient(circle, #34d399, transparent); }
.decision-glow.ok      { background: radial-gradient(circle, #fbbf24, transparent); }
.decision-glow.watch   { background: radial-gradient(circle, #fb923c, transparent); }
.decision-glow.wait,.decision-glow.no { background: radial-gradient(circle, #818cf8, transparent); }

.decision-top { display: flex; align-items: center; gap: 20rpx; position: relative; z-index: 1; }

/* 表情圆 */
.decision-face-wrap {
  width: 116rpx; height: 116rpx; border-radius: 50%; flex-shrink: 0;
  display: flex; align-items: center; justify-content: center;
  background: rgba(255,255,255,.08);
  border: 3rpx solid rgba(255,255,255,.2);
  animation: float-up 3s ease-in-out infinite;
  box-shadow: 0 0 24rpx rgba(0,0,0,.3);
}
.decision-face-wrap.buy     { background: rgba(251,113,133,.18);  border-color: rgba(251,113,133,.55); box-shadow: 0 0 28rpx rgba(251,113,133,.2); }
.decision-face-wrap.short_s { background: rgba(52,211,153,.18);   border-color: rgba(52,211,153,.55);  box-shadow: 0 0 28rpx rgba(52,211,153,.2); }
.decision-face-wrap.ok      { background: rgba(251,191,36,.18);   border-color: rgba(251,191,36,.55);  box-shadow: 0 0 28rpx rgba(251,191,36,.18); }
.decision-face-wrap.watch   { background: rgba(251,146,60,.18);   border-color: rgba(251,146,60,.55); }
.decision-face { font-size: 68rpx; }

.decision-text { flex: 1; }
.decision-verdict {
  display: block; font-size: 42rpx; font-weight: 900; color: #f1f5f9;
  letter-spacing: 1rpx; line-height: 1.2;
}
.decision-sub { display: block; font-size: 24rpx; color: rgba(255,255,255,.5); margin-top: 8rpx; line-height: 1.7; }
.decision-meta { display: flex; gap: 8rpx; flex-wrap: wrap; margin-top: 12rpx; }
.meta-tag {
  font-size: 18rpx; padding: 3rpx 12rpx; border-radius: 14rpx;
  background: rgba(255,255,255,.1); color: rgba(255,255,255,.6);
  border: 1rpx solid rgba(255,255,255,.12);
}
.meta-tag.accent { background: rgba(251,191,36,.2); color: #fbbf24; border-color: rgba(251,191,36,.35); }

/* 评分圆 */
.score-circle {
  display: flex; flex-direction: column; align-items: center; flex-shrink: 0;
  width: 96rpx; height: 96rpx; border-radius: 50%;
  background: rgba(255,255,255,.07);
  border: 3rpx solid rgba(251,191,36,.35);
  justify-content: center;
  box-shadow: 0 0 20rpx rgba(251,191,36,.15), inset 0 0 16rpx rgba(251,191,36,.06);
}
.score-circle.buy     { border-color: rgba(251,113,133,.65); box-shadow: 0 0 20rpx rgba(251,113,133,.2); }
.score-circle.short_s { border-color: rgba(52,211,153,.65);  box-shadow: 0 0 20rpx rgba(52,211,153,.2); }
.score-circle.ok      { border-color: rgba(251,191,36,.65);  box-shadow: 0 0 20rpx rgba(251,191,36,.2); }
.score-num { font-size: 44rpx; font-weight: 900; color: #fbbf24; line-height: 1; }
.score-den { font-size: 17rpx; color: rgba(255,255,255,.4); margin-top: -2rpx; }

/* 评分进度条 */
.score-bar-wrap {
  margin: 18rpx 0 12rpx; height: 8rpx;
  background: rgba(255,255,255,.08); border-radius: 6rpx; overflow: hidden;
  position: relative; z-index: 1;
}
.score-bar-fill { height: 100%; border-radius: 6rpx; transition: width .6s cubic-bezier(.34,1.56,.64,1); }
.score-bar-fill.buy     { background: linear-gradient(90deg, #f43f5e, #fb7185, #fda4af); }
.score-bar-fill.short_s { background: linear-gradient(90deg, #059669, #34d399, #6ee7b7); }
.score-bar-fill.ok      { background: linear-gradient(90deg, #d97706, #fbbf24, #fde68a); }
.score-bar-fill.watch   { background: linear-gradient(90deg, #ea580c, #fb923c, #fdba74); }
.score-bar-fill.wait,.score-bar-fill.no { background: linear-gradient(90deg, #475569, #94a3b8); }

.decision-bottom {
  display: flex; justify-content: space-between; align-items: center;
  position: relative; z-index: 1;
}
.score-stars { font-size: 28rpx; color: #fbbf24; letter-spacing: 4rpx; }
.score-label-wrap { display: flex; align-items: center; gap: 14rpx; }
.score-label {
  font-size: 22rpx; padding: 5rpx 20rpx; border-radius: 24rpx; font-weight: 800;
  letter-spacing: .5rpx;
}
.score-label.buy     { background: linear-gradient(135deg, rgba(244,63,94,.3), rgba(251,113,133,.2)); color: #fb7185; }
.score-label.short_s { background: linear-gradient(135deg, rgba(5,150,105,.3), rgba(52,211,153,.2)); color: #34d399; }
.score-label.ok      { background: linear-gradient(135deg, rgba(217,119,6,.3), rgba(251,191,36,.2)); color: #fbbf24; }
.score-label.watch   { background: linear-gradient(135deg, rgba(234,88,12,.3), rgba(251,146,60,.2)); color: #fb923c; }
.score-label.no,.score-label.wait { background: rgba(148,163,184,.15); color: #94a3b8; }
.update-time { font-size: 18rpx; color: rgba(255,255,255,.3); }

/* ══════════════════════════════════════════════
   MACD 叉口通知条
══════════════════════════════════════════════ */
.macd-cross-bar {
  display: flex; align-items: center; gap: 16rpx;
  margin: 0 20rpx 16rpx; padding: 18rpx 22rpx;
  border-radius: 22rpx; border: 1.5rpx solid;
  backdrop-filter: blur(8px);
}
.macd-cross-bar.golden {
  background: linear-gradient(135deg, rgba(52,211,153,.1), rgba(16,185,129,.08));
  border-color: rgba(52,211,153,.45);
  box-shadow: 0 4rpx 20rpx rgba(52,211,153,.1);
}
.macd-cross-bar.dead {
  background: linear-gradient(135deg, rgba(251,113,133,.1), rgba(244,63,94,.08));
  border-color: rgba(251,113,133,.45);
  box-shadow: 0 4rpx 20rpx rgba(251,113,133,.1);
}
.macd-cross-icon { font-size: 38rpx; flex-shrink: 0; }
.macd-cross-info { flex: 1; min-width: 0; }
.macd-cross-title {
  display: block; font-size: 27rpx; font-weight: 900; letter-spacing: .5rpx;
}
.macd-cross-bar.golden .macd-cross-title { color: #34d399; }
.macd-cross-bar.dead   .macd-cross-title { color: #fb7185; }
.macd-cross-desc {
  display: block; font-size: 20rpx; color: rgba(255,255,255,.45); margin-top: 4rpx;
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.macd-cross-hint {
  font-size: 26rpx; font-weight: 900; flex-shrink: 0;
}
.macd-cross-bar.golden .macd-cross-hint { color: #34d399; }
.macd-cross-bar.dead   .macd-cross-hint { color: #fb7185; }

/* ══════════════════════════════════════════════
   信号详情
══════════════════════════════════════════════ */
.section-title {
  display: flex; justify-content: space-between; align-items: center;
  margin: 20rpx 24rpx 12rpx; font-size: 28rpx; font-weight: 800;
  color: rgba(255,255,255,.85);
}
.section-title-plain {
  margin: 20rpx 24rpx 12rpx; font-size: 28rpx; font-weight: 800;
  color: rgba(255,255,255,.85); display: flex; align-items: center; justify-content: space-between;
}
.section-sub { font-size: 20rpx; color: rgba(255,255,255,.3); font-weight: 400; }
.dir-tag { font-size: 22rpx; padding: 5rpx 20rpx; border-radius: 22rpx; font-weight: 800; }
.dir-tag.long  { background: rgba(251,113,133,.2); color: #fb7185; }
.dir-tag.short { background: rgba(52,211,153,.2);  color: #34d399; }

.signal-detail {
  margin: 0 20rpx;
  background: rgba(255,255,255,.05);
  backdrop-filter: blur(10px);
  border-radius: 26rpx;
  border: 1.5rpx solid rgba(255,255,255,.1); overflow: hidden; padding: 20rpx 20rpx 0;
}
.signal-detail.long  { border-color: rgba(251,113,133,.35); }
.signal-detail.short { border-color: rgba(52,211,153,.35); }
.detail-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14rpx; padding-bottom: 18rpx; }
.detail-cell {
  background: rgba(255,255,255,.06); border-radius: 18rpx; padding: 18rpx 16rpx;
  border: 1rpx solid rgba(255,255,255,.08);
}
.dc-label { display: block; font-size: 20rpx; color: rgba(255,255,255,.4); margin-bottom: 6rpx; }
.dc-val   { display: block; font-size: 32rpx; font-weight: 900; color: #f1f5f9; }
.dc-val.accent { color: #fbbf24; }
.dc-val.loss   { color: #fb923c; }

/* 止盈止损 */
.sl-tp-block {
  background: rgba(0,0,0,.25); border-radius: 18rpx;
  border: 1rpx solid rgba(255,255,255,.08); margin-top: 16rpx; overflow: hidden;
}
.sl-tp-title {
  padding: 14rpx 20rpx;
  background: linear-gradient(135deg, rgba(129,140,248,.15), rgba(192,132,252,.1));
  font-size: 24rpx; font-weight: 800; color: #a5b4fc;
  border-bottom: 1rpx solid rgba(255,255,255,.07);
}
.sl-row {
  display: flex; align-items: center; padding: 14rpx 20rpx;
  border-bottom: 1rpx solid rgba(255,255,255,.05); gap: 16rpx;
}
.sl-row:last-child { border-bottom: none; }
.sl-tag {
  font-size: 20rpx; font-weight: 700; padding: 5rpx 16rpx; border-radius: 12rpx;
  flex-shrink: 0; min-width: 120rpx; text-align: center;
}
.sl-tag.stop     { background: rgba(244,63,94,.2);   color: #f87171; }
.sl-tag.entry-tag { background: rgba(255,255,255,.08); color: #94a3b8; }
.sl-tag.tp1-tag.long  { background: rgba(52,211,153,.15); color: #34d399; }
.sl-tag.tp2-tag.long  { background: rgba(52,211,153,.22); color: #34d399; }
.sl-tag.tp3-tag.long  { background: rgba(52,211,153,.3);  color: #6ee7b7; }
.sl-tag.tp1-tag.short { background: rgba(244,63,94,.15);  color: #f87171; }
.sl-tag.tp2-tag.short { background: rgba(244,63,94,.22);  color: #f87171; }
.sl-tag.tp3-tag.short { background: rgba(244,63,94,.3);   color: #fca5a5; }
.sl-tag.tp1-tag { background: rgba(52,211,153,.15); color: #34d399; }
.sl-tag.tp2-tag { background: rgba(52,211,153,.22); color: #34d399; }
.sl-tag.tp3-tag { background: rgba(52,211,153,.3);  color: #6ee7b7; }
.sl-price { font-size: 28rpx; font-weight: 900; flex: 1; color: #f1f5f9; }
.sl-price.stop { color: #f87171; }
.tp-long    { color: #34d399; }
.tp-long-hi { color: #6ee7b7; }
.tp-short    { color: #f87171; }
.tp-short-hi { color: #fca5a5; }
.sl-hint { font-size: 20rpx; color: rgba(255,255,255,.3); flex-shrink: 0; }

/* 仓位建议 */
.pos-row {
  display: flex; gap: 0; border-top: 1rpx solid rgba(255,255,255,.06);
  flex-wrap: wrap; padding-top: 12rpx; padding-bottom: 16rpx;
}
.pos-item { flex: 1; min-width: 140rpx; padding: 8rpx 0; text-align: center; border-right: 1rpx solid rgba(255,255,255,.06); }
.pos-item:last-child { border-right: none; }
.pos-label { display: block; font-size: 18rpx; color: rgba(255,255,255,.35); margin-bottom: 4rpx; }
.pos-val   { display: block; font-size: 22rpx; font-weight: 700; color: #a5b4fc; }
.pos-row .pos-item:first-child .pos-val { color: #fbbf24; font-size: 24rpx; }

/* ══════════════════════════════════════════════
   多空能量对比
══════════════════════════════════════════════ */
.energy-card {
  margin: 0 20rpx 18rpx; padding: 22rpx 26rpx;
  background: rgba(255,255,255,.05);
  backdrop-filter: blur(12px);
  border-radius: 30rpx; border: 1.5rpx solid rgba(255,255,255,.1);
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,.25);
}
.energy-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 14rpx; }
.energy-title { font-size: 26rpx; font-weight: 800; color: rgba(255,255,255,.6); }
.energy-dom {
  font-size: 24rpx; font-weight: 800; padding: 5rpx 18rpx; border-radius: 20rpx;
}
.energy-dom.bull      { color: #fb7185; background: rgba(251,113,133,.18); }
.energy-dom.bull_weak { color: #fb923c; background: rgba(251,146,60,.15); }
.energy-dom.bear      { color: #34d399; background: rgba(52,211,153,.15); }
.energy-dom.bear_weak { color: #94a3b8; background: rgba(148,163,184,.12); }
.energy-dom.neutral   { color: #94a3b8; background: rgba(148,163,184,.1); }

.energy-bar-wrap { display: flex; height: 56rpx; border-radius: 18rpx; overflow: hidden; gap: 4rpx; }
.energy-bull-bar {
  background: linear-gradient(90deg, #be123c, #f43f5e, #fb7185);
  display: flex; align-items: center; justify-content: center;
  transition: width .6s cubic-bezier(.34,1.56,.64,1); min-width: 60rpx; border-radius: 16rpx 0 0 16rpx;
  box-shadow: inset 0 2rpx 0 rgba(255,255,255,.15);
}
.energy-bear-bar {
  background: linear-gradient(90deg, #059669, #10b981, #34d399);
  display: flex; align-items: center; justify-content: center;
  transition: width .6s cubic-bezier(.34,1.56,.64,1); min-width: 60rpx; border-radius: 0 16rpx 16rpx 0;
  box-shadow: inset 0 2rpx 0 rgba(255,255,255,.15);
}
.energy-bar-label { font-size: 24rpx; font-weight: 900; color: rgba(255,255,255,.92); text-shadow: 0 1px 4px rgba(0,0,0,.6); }

/* ══════════════════════════════════════════════
   多空条件感知
══════════════════════════════════════════════ */
.section-title-plain { margin: 20rpx 24rpx 12rpx; }

.cond-wrap {
  display: flex; margin: 0 20rpx;
  background: rgba(255,255,255,.05);
  backdrop-filter: blur(12px);
  border-radius: 30rpx; border: 1.5rpx solid rgba(255,255,255,.1); overflow: hidden;
  box-shadow: 0 4rpx 24rpx rgba(0,0,0,.2);
}
.cond-col { flex: 1; padding: 20rpx 16rpx; }
.cond-divider { width: 1rpx; background: rgba(255,255,255,.08); }
.cond-col-title { font-size: 24rpx; font-weight: 900; margin-bottom: 16rpx; letter-spacing: .5rpx; }
.long-color  { color: #fb7185; }
.short-color { color: #34d399; }

.cond-item { display: flex; gap: 10rpx; align-items: flex-start; margin-bottom: 16rpx; }
.cond-icon { font-size: 22rpx; line-height: 1.5; flex-shrink: 0; }
.cond-text { display: flex; flex-direction: column; }
.cond-label { font-size: 22rpx; color: rgba(255,255,255,.45); font-weight: 600; }
.cond-tip   { font-size: 18rpx; color: rgba(255,255,255,.25); margin-top: 2rpx; }
.cond-item.ok .cond-label { color: rgba(255,255,255,.88); }
.cond-item.ok .cond-tip   { color: #4ade80; }

.cond-score-bar {
  display: flex; align-items: center; gap: 10rpx;
  height: 8rpx; background: rgba(255,255,255,.07); border-radius: 5rpx; overflow: hidden;
  position: relative; margin-top: 6rpx;
}
.cond-score-fill { height: 100%; border-radius: 5rpx; transition: width .4s; }
.cond-score-fill.long  { background: linear-gradient(90deg, #f43f5e, #fb7185); }
.cond-score-fill.short { background: linear-gradient(90deg, #059669, #34d399); }
.cond-score-txt {
  position: absolute; right: 0; top: -24rpx;
  font-size: 18rpx; color: rgba(255,255,255,.3);
}

/* ══════════════════════════════════════════════
   指标卡 2×4
══════════════════════════════════════════════ */
.ind-grid {
  display: grid; grid-template-columns: repeat(4, 1fr);
  gap: 10rpx; margin: 0 20rpx;
}
.ind-card {
  background: rgba(255,255,255,.05);
  border: 1.5rpx solid rgba(255,255,255,.1);
  border-radius: 20rpx; padding: 14rpx 8rpx 10rpx; text-align: center;
  position: relative; overflow: hidden;
  backdrop-filter: blur(8px);
}
.ind-card.long  { background: rgba(251,113,133,.08); border-color: rgba(251,113,133,.3); }
.ind-card.short { background: rgba(52,211,153,.08);  border-color: rgba(52,211,153,.3); }
.ind-top { display: flex; align-items: center; justify-content: center; gap: 6rpx; margin-bottom: 6rpx; }
.ind-dot { width: 10rpx; height: 10rpx; border-radius: 50%; flex-shrink: 0; }
.ind-dot.red   { background: #fb7185; box-shadow: 0 0 5px #fb7185; }
.ind-dot.green { background: #34d399; box-shadow: 0 0 5px #34d399; }
.ind-dot.gray  { background: #475569; }
.ind-name { font-size: 18rpx; color: rgba(255,255,255,.4); }
.ind-val  { display: block; font-size: 30rpx; font-weight: 900; color: #f1f5f9; margin: 2rpx 0; }
.ind-val.long  { color: #fb7185; }
.ind-val.short { color: #34d399; }
.ind-tip  { display: block; font-size: 14rpx; color: rgba(255,255,255,.28); line-height: 1.4; min-height: 2em; }
.ind-prog-wrap { margin: 8rpx 6rpx 4rpx; height: 5rpx; background: rgba(255,255,255,.06); border-radius: 3rpx; overflow: hidden; }
.ind-prog-fill { height: 100%; border-radius: 3rpx; background: #475569; }
.ind-prog-fill.long  { background: linear-gradient(90deg, #f43f5e, #fb7185); }
.ind-prog-fill.short { background: linear-gradient(90deg, #059669, #34d399); }
.ind-state { display: block; font-size: 16rpx; margin-top: 2rpx; }
.ind-state.red   { color: #fb7185; }
.ind-state.green { color: #34d399; }
.ind-state.gray  { color: #475569; }

/* 市场摘要栏 */
.market-summary {
  display: flex; align-items: center; justify-content: space-around;
  margin: 14rpx 20rpx 0; padding: 18rpx 16rpx;
  background: rgba(255,255,255,.05);
  backdrop-filter: blur(8px);
  border: 1.5rpx solid rgba(255,255,255,.1); border-radius: 22rpx;
}
.ms-item { display: flex; align-items: center; gap: 10rpx; flex: 1; justify-content: center; }
.ms-icon { font-size: 28rpx; }
.ms-text { display: flex; flex-direction: column; }
.ms-label { font-size: 16rpx; color: rgba(255,255,255,.3); }
.ms-val   { font-size: 24rpx; font-weight: 800; color: rgba(255,255,255,.6); }
.ms-val.up { color: #fb7185; }
.ms-val.dn { color: #34d399; }
.ms-divider { width: 1rpx; height: 36rpx; background: rgba(255,255,255,.08); }

/* ══════════════════════════════════════════════
   策略贴士（横向滑动）
══════════════════════════════════════════════ */
.tips-scroll { margin: 0 20rpx; }
.tips-row { display: flex; gap: 14rpx; padding-bottom: 8rpx; width: max-content; }
.tip-card {
  display: inline-flex; flex-direction: column;
  flex-shrink: 0; width: 250rpx;
  border-radius: 24rpx; padding: 22rpx 18rpx;
  border: 1.5rpx solid rgba(255,255,255,.12);
  background: rgba(255,255,255,.06);
  backdrop-filter: blur(10px);
  white-space: normal;
}
.tip-pin   { background: rgba(6,182,212,.08);  border-color: rgba(6,182,212,.35); }
.tip-vol   { background: rgba(129,140,248,.08); border-color: rgba(129,140,248,.35); }
.tip-long  { background: rgba(251,113,133,.08); border-color: rgba(251,113,133,.35); }
.tip-short { background: rgba(52,211,153,.08);  border-color: rgba(52,211,153,.35); }
.tip-stop  { background: rgba(251,146,60,.08);  border-color: rgba(251,146,60,.35); }
.tip-score { background: rgba(251,191,36,.08);  border-color: rgba(251,191,36,.35); }
.tip-time  { background: rgba(192,132,252,.08); border-color: rgba(192,132,252,.35); }
.tip-rr    { background: rgba(56,189,248,.08);  border-color: rgba(56,189,248,.35); }

.tip-icon  { display: block; font-size: 38rpx; margin-bottom: 10rpx; }
.tip-title { display: block; font-size: 24rpx; font-weight: 900; color: #f1f5f9; margin-bottom: 7rpx; }
.tip-body  { display: block; font-size: 20rpx; color: rgba(255,255,255,.5); white-space: pre-line; line-height: 1.7; flex: 1; }
.tip-tag   {
  margin-top: 14rpx; display: inline-block;
  font-size: 16rpx; padding: 4rpx 14rpx; border-radius: 14rpx;
  background: rgba(255,255,255,.1); color: rgba(255,255,255,.5);
}
.tip-pin   .tip-tag { background: rgba(6,182,212,.2);   color: #22d3ee; }
.tip-vol   .tip-tag { background: rgba(129,140,248,.2); color: #a5b4fc; }
.tip-long  .tip-tag { background: rgba(251,113,133,.2); color: #fb7185; }
.tip-short .tip-tag { background: rgba(52,211,153,.2);  color: #34d399; }
.tip-stop  .tip-tag { background: rgba(251,146,60,.2);  color: #fb923c; }
.tip-score .tip-tag { background: rgba(251,191,36,.2);  color: #fbbf24; }
.tip-time  .tip-tag { background: rgba(192,132,252,.2); color: #c084fc; }
.tip-rr    .tip-tag { background: rgba(56,189,248,.2);  color: #38bdf8; }

/* ══════════════════════════════════════════════
   K线图区域 + 周期切换
══════════════════════════════════════════════ */
.kline-section { margin: 0 0 6rpx; }

.kline-title-row {
  display: flex; align-items: center; justify-content: space-between;
  padding: 12rpx 22rpx 10rpx; flex-wrap: nowrap;
}
.kline-title-left { display: flex; align-items: center; gap: 10rpx; flex: 1; min-width: 0; overflow: hidden; }
.kline-section-icon { font-size: 26rpx; flex-shrink: 0; }

/* 周期按钮 */
.period-bar-inline { display: flex; gap: 7rpx; flex-wrap: nowrap; overflow-x: auto; }
.period-btn-sm {
  flex-shrink: 0;
  background: rgba(255,255,255,.06);
  border: 1rpx solid rgba(255,255,255,.1);
  border-radius: 12rpx; padding: 5rpx 16rpx; font-size: 21rpx; color: rgba(255,255,255,.45);
  transition: all .2s;
}
.period-btn-sm.active {
  background: linear-gradient(135deg, rgba(129,140,248,.3), rgba(192,132,252,.2));
  border-color: rgba(165,180,252,.6); color: #a5b4fc; font-weight: 900;
  box-shadow: 0 2rpx 10rpx rgba(129,140,248,.25);
}
.period-btn-sm.more-btn { color: rgba(255,255,255,.5); border-style: dashed; }
.period-btn-sm.more-btn.active { color: #a5b4fc; border-color: #a5b4fc; border-style: solid; }

/* 更多周期面板 */
.period-more-panel {
  display: flex; flex-wrap: wrap; gap: 12rpx;
  padding: 16rpx 22rpx 14rpx;
  background: rgba(20,15,50,.8);
  backdrop-filter: blur(12px);
  border-bottom: 1rpx solid rgba(165,180,252,.15);
}
.period-more-btn {
  background: rgba(255,255,255,.06); border: 1rpx solid rgba(255,255,255,.12);
  border-radius: 14rpx; padding: 9rpx 22rpx; font-size: 22rpx; color: rgba(255,255,255,.5);
}
.period-more-btn.active {
  background: linear-gradient(135deg, rgba(129,140,248,.3), rgba(192,132,252,.2));
  border-color: rgba(165,180,252,.6); color: #a5b4fc; font-weight: 900;
}

/* 图例 */
.chart-legend { display: flex; align-items: center; gap: 8rpx; font-size: 18rpx; }
.leg-boll-u { color: #c084fc; }
.leg-boll-l { color: #22d3ee; }
.leg-ma5    { color: #fb923c; }
.leg-ma10   { color: #60a5fa; }
.kview-badge {
  font-size: 18rpx; color: #a5b4fc;
  background: rgba(129,140,248,.15); border: 1rpx solid rgba(129,140,248,.35);
  padding: 4rpx 16rpx; border-radius: 22rpx;
}

/* K线画布 */
.kcanvas-wrap {
  margin: 4rpx 22rpx 0; position: relative;
  background: #07090f; border-radius: 28rpx;
  border: 1.5rpx solid rgba(96,165,250,.2); overflow: hidden;
  box-shadow: 0 10rpx 40rpx rgba(0,0,0,.6), inset 0 1rpx 0 rgba(255,255,255,.04);
}
.kcanvas { width: 100%; height: 590rpx; display: block; }

.kcanvas-hint {
  position: absolute; bottom: 10rpx; left: 50%;
  transform: translateX(-50%);
  font-size: 16rpx; color: rgba(255,255,255,.2);
  pointer-events: none; white-space: nowrap;
}

/* 触摸浮窗 */
.ktooltip {
  position: absolute; top: 12rpx;
  background: rgba(10,12,30,.94);
  border: 1rpx solid rgba(129,140,248,.35); border-radius: 14rpx;
  padding: 12rpx 18rpx; min-width: 140rpx;
  pointer-events: none; z-index: 10;
  box-shadow: 0 8rpx 30rpx rgba(0,0,0,.7);
  backdrop-filter: blur(10px);
}
.ktt-time { font-size: 18rpx; color: rgba(255,255,255,.45); display: block; margin-bottom: 6rpx; }
.ktt-row  { display: flex; justify-content: space-between; gap: 14rpx; margin: 3rpx 0; }
.ktt-l    { font-size: 18rpx; color: rgba(255,255,255,.3); }
.ktt-v    { font-size: 18rpx; color: #e2e8f0; font-weight: 700; }
.ktt-v.up { color: #fb7185; }
.ktt-v.dn { color: #34d399; }
.ktt-div  { height: 1rpx; background: rgba(255,255,255,.08); margin: 6rpx 0; }

/* ══════════════════════════════════════════════
   大趋势卡片 v2
══════════════════════════════════════════════ */
.trend-card-v2 {
  margin: 10rpx 20rpx 6rpx;
  border-radius: 30rpx; overflow: hidden;
  background: rgba(255,255,255,.05);
  backdrop-filter: blur(14px);
  border: 1.5rpx solid rgba(255,255,255,.12);
  box-shadow: 0 8rpx 36rpx rgba(0,0,0,.35);
}
.trend-card-v2.bull      { border-color: rgba(251,113,133,.5); box-shadow: 0 8rpx 36rpx rgba(251,113,133,.15); }
.trend-card-v2.bull_weak { border-color: rgba(251,146,60,.38); }
.trend-card-v2.bear, .trend-card-v2.down { border-color: rgba(52,211,153,.5); box-shadow: 0 8rpx 36rpx rgba(52,211,153,.15); }
.trend-card-v2.bear_weak { border-color: rgba(148,163,184,.25); }

.trend-card-top {
  padding: 22rpx 26rpx 16rpx;
  border-bottom: 1rpx solid rgba(255,255,255,.07);
}
.trend-card-title-row {
  display: flex; align-items: center; justify-content: space-between; margin-bottom: 12rpx;
}
.trend-card-period { font-size: 27rpx; font-weight: 800; color: rgba(255,255,255,.8); }
.trend-card-badge {
  display: flex; align-items: center; gap: 8rpx;
  padding: 7rpx 22rpx; border-radius: 30rpx; font-weight: 900;
}
.trend-card-badge.bull      { background: rgba(251,113,133,.2);  color: #fb7185; }
.trend-card-badge.bull_weak { background: rgba(251,146,60,.18);  color: #fb923c; }
.trend-card-badge.bear,
.trend-card-badge.down      { background: rgba(52,211,153,.2);   color: #34d399; }
.trend-card-badge.bear_weak { background: rgba(148,163,184,.15); color: #94a3b8; }
.trend-card-badge.neutral   { background: rgba(148,163,184,.12); color: #94a3b8; }
.trend-badge-icon { font-size: 28rpx; }
.trend-badge-text { font-size: 27rpx; letter-spacing: 1rpx; }
.trend-card-desc { font-size: 23rpx; color: rgba(255,255,255,.45); line-height: 1.65; }

.trend-card-mid {
  display: flex; align-items: center; justify-content: space-around;
  padding: 18rpx 14rpx;
  border-bottom: 1rpx solid rgba(255,255,255,.06);
}
.trend-ma-item { display: flex; flex-direction: column; align-items: center; gap: 7rpx; flex: 1; }
.trend-ma-label { font-size: 20rpx; color: rgba(255,255,255,.35); }
.trend-ma-val   { font-size: 26rpx; font-weight: 900; color: #f1f5f9; }
.trend-ma-val.green { color: #fb7185; }
.trend-ma-val.red   { color: #34d399; }
.trend-ma-divider { width: 1rpx; height: 44rpx; background: rgba(255,255,255,.08); }

.trend-card-bar-wrap {
  display: flex; align-items: center; gap: 16rpx;
  padding: 14rpx 26rpx 18rpx;
}
.trend-card-bar-track {
  flex: 1; height: 10rpx; background: rgba(255,255,255,.07); border-radius: 6rpx; overflow: hidden;
}
.trend-card-bar-fill { height: 100%; border-radius: 6rpx; transition: width .5s cubic-bezier(.34,1.56,.64,1); }
.trend-card-bar-fill.bull      { background: linear-gradient(90deg, #f43f5e, #fb7185, #fda4af); }
.trend-card-bar-fill.bull_weak { background: linear-gradient(90deg, #ea580c, #fb923c, #fdba74); }
.trend-card-bar-fill.bear, .trend-card-bar-fill.down { background: linear-gradient(90deg, #059669, #10b981, #6ee7b7); }
.trend-card-bar-fill.bear_weak { background: linear-gradient(90deg, #475569, #94a3b8); }
.trend-card-bar-fill.neutral   { background: linear-gradient(90deg, #334155, #64748b); }
.trend-card-bar-label { font-size: 22rpx; color: rgba(255,255,255,.35); flex-shrink: 0; min-width: 130rpx; text-align: right; }

/* 旧样式 */
.trend-card { display: none; }
.trend-card-header { display: none; }
.trend-card-title  { display: none; }
.trend-label { display: none; }
.trend-period-bar  { display: none; }
.trend-period-btn  { display: none; }
.trend-desc  { display: none; }
.trend-zones { display: none; }
.trend-zone-item   { display: none; }
.tz-label    { display: none; }
.tz-val      { display: none; }
.trend-zone-divider { display: none; }
.trend-ma-row { display: none; }
.ma-tag { font-size: 20rpx; color: #475569; background: rgba(255,255,255,.04); padding: 4rpx 12rpx; border-radius: 8rpx; }
.trend-inline-bar    { display: none; }
.trend-detail-wrap   { display: none; }
.trend-detail-inner  { display: none; }
.trend-detail-toggle { display: none; }
.period-bar { display: none; }
.period-btn { display: none; }

/* ══════════════════════════════════════════════
   风控状态栏
══════════════════════════════════════════════ */
.risk-bar {
  display: flex; justify-content: space-between; align-items: center;
  margin: 0 20rpx 16rpx; padding: 14rpx 22rpx; border-radius: 20rpx;
  background: rgba(129,140,248,.08); border: 1.5rpx solid rgba(129,140,248,.3);
}
.risk-bar.cooldown { background: rgba(251,146,60,.08); border-color: rgba(251,146,60,.35); }
.risk-bar.max_loss { background: rgba(251,113,133,.08); border-color: rgba(251,113,133,.35); }
.risk-left { display: flex; align-items: center; gap: 10rpx; }
.risk-icon { font-size: 24rpx; }
.risk-txt  { font-size: 22rpx; color: #a5b4fc; font-weight: 700; }
.risk-bar.cooldown .risk-txt { color: #fb923c; }
.risk-bar.max_loss .risk-txt { color: #fb7185; }
.risk-right { font-size: 20rpx; color: rgba(255,255,255,.35); }

/* ══════════════════════════════════════════════
   底部 / 错误
══════════════════════════════════════════════ */
.footer {
  text-align: center; padding: 28rpx 0 60rpx;
  display: flex; flex-direction: column; align-items: center; gap: 8rpx;
}
.footer-badge {
  font-size: 22rpx; font-weight: 700;
  background: linear-gradient(135deg, rgba(251,191,36,.15), rgba(96,165,250,.12));
  border: 1rpx solid rgba(255,255,255,.1);
  border-radius: 30rpx; padding: 8rpx 28rpx;
  color: rgba(255,255,255,.5);
  letter-spacing: .5rpx; margin-bottom: 8rpx;
}
.footer-txt { display: block; font-size: 20rpx; color: rgba(255,255,255,.18); line-height: 2; }

.error-bar {
  margin: 0 20rpx 24rpx; padding: 18rpx 22rpx;
  background: rgba(251,113,133,.08); border: 1.5rpx solid rgba(251,113,133,.35);
  border-radius: 20rpx; backdrop-filter: blur(8px);
}
.error-bar text { display: block; font-size: 24rpx; color: #fda4af; }
.error-hint { font-size: 20rpx !important; color: rgba(255,255,255,.4) !important; margin-top: 6rpx; }

/* ── 分隔线 ── */
.tp-row { display: flex; gap: 0; border-top: 1rpx solid rgba(255,255,255,.06); }
.tp-item { flex: 1; padding: 16rpx 0; text-align: center; border-right: 1rpx solid rgba(255,255,255,.06); }
.tp-item:last-child { border-right: none; }
.tp-label { display: block; font-size: 18rpx; color: rgba(255,255,255,.35); margin-bottom: 4rpx; }
.tp-val   { display: block; font-size: 24rpx; font-weight: 800; color: #34d399; }

/* ══════════════════════════════════════════════
   免责声明弹窗
══════════════════════════════════════════════ */
@keyframes pop-in { 0%{transform:scale(.8);opacity:0} 70%{transform:scale(1.04)} 100%{transform:scale(1);opacity:1} }

.disclaimer-mask {
  position: fixed; inset: 0; z-index: 9999;
  background: rgba(0,0,0,.78);
  display: flex; align-items: center; justify-content: center;
  backdrop-filter: blur(8px);
}
.disclaimer-box {
  margin: 0 44rpx; padding: 44rpx 38rpx 36rpx;
  background: linear-gradient(160deg, #0d1428 0%, #0a1020 100%);
  border: 1.5rpx solid rgba(251,191,36,.35);
  border-radius: 40rpx;
  box-shadow: 0 24rpx 80rpx rgba(0,0,0,.7), 0 0 0 1rpx rgba(251,191,36,.12);
  animation: pop-in .35s cubic-bezier(.34,1.56,.64,1);
}
.disclaimer-icon { font-size: 64rpx; text-align: center; display: block; margin-bottom: 18rpx; }
.disclaimer-title {
  display: block; font-size: 40rpx; font-weight: 900; text-align: center;
  background: linear-gradient(135deg, #fbbf24 0%, #fb923c 100%);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  background-clip: text; margin-bottom: 28rpx; letter-spacing: 2rpx;
}
.disclaimer-content {
  background: rgba(255,255,255,.04); border-radius: 20rpx;
  border: 1rpx solid rgba(255,255,255,.08);
  padding: 24rpx 24rpx; margin-bottom: 30rpx;
}
.disclaimer-txt {
  display: block; font-size: 24rpx; color: rgba(255,255,255,.55);
  line-height: 1.9; margin-bottom: 6rpx;
}
.disclaimer-txt:last-child { margin-bottom: 0; color: rgba(255,255,255,.35); }
.disclaimer-btn {
  background: linear-gradient(135deg, #d97706, #fbbf24);
  border-radius: 60rpx; padding: 24rpx 0; text-align: center;
  box-shadow: 0 6rpx 28rpx rgba(251,191,36,.35);
  transition: all .15s;
}
.disclaimer-btn text {
  font-size: 30rpx; font-weight: 900; color: #0d1117; letter-spacing: 1rpx;
}

/* ══════════════════════════════════════════════
   导航栏会员按钮
══════════════════════════════════════════════ */
.nav-vip-btn {
  display: flex; flex-direction: column; align-items: center; gap: 2rpx;
  background: linear-gradient(135deg, rgba(217,119,6,.18), rgba(251,191,36,.1));
  border: 1rpx solid rgba(251,191,36,.4);
  padding: 8rpx 20rpx; border-radius: 28rpx;
  transition: all .2s;
}
.nav-vip-btn.vip-on {
  background: linear-gradient(135deg, rgba(251,191,36,.25), rgba(251,146,60,.2));
  border-color: rgba(251,191,36,.65);
  box-shadow: 0 0 14rpx rgba(251,191,36,.25);
}
.nav-vip-icon  { font-size: 24rpx; line-height: 1; }
.nav-vip-label { font-size: 17rpx; color: #fbbf24; font-weight: 700; }

/* ══════════════════════════════════════════════
   会员升级弹窗
══════════════════════════════════════════════ */
@keyframes slide-up { 0%{transform:translateY(60rpx);opacity:0} 100%{transform:translateY(0);opacity:1} }

.vip-mask {
  position: fixed; inset: 0; z-index: 9998;
  background: rgba(0,0,0,.72);
  display: flex; align-items: flex-end; justify-content: center;
  backdrop-filter: blur(6px);
}
.vip-box {
  width: 100%; max-height: 88vh;
  background: linear-gradient(180deg, #0d1a2e 0%, #090d18 100%);
  border-top-left-radius: 44rpx; border-top-right-radius: 44rpx;
  border: 1.5rpx solid rgba(251,191,36,.25);
  border-bottom: none;
  padding: 40rpx 32rpx 60rpx;
  box-shadow: 0 -20rpx 60rpx rgba(0,0,0,.7);
  animation: slide-up .3s cubic-bezier(.34,1.56,.64,1);
  overflow-y: auto;
}
.vip-header { text-align: center; margin-bottom: 36rpx; }
.vip-crown  { display: block; font-size: 72rpx; margin-bottom: 14rpx; }
.vip-title  {
  display: block; font-size: 44rpx; font-weight: 900; letter-spacing: 2rpx;
  background: linear-gradient(135deg, #fbbf24 0%, #fb923c 60%, #f59e0b 100%);
  -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  background-clip: text; margin-bottom: 10rpx;
}
.vip-slogan { display: block; font-size: 24rpx; color: rgba(255,255,255,.4); }

/* 功能列表 */
.vip-features { margin-bottom: 32rpx; }
.vip-feat-row {
  display: flex; align-items: center; gap: 18rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(255,255,255,.06);
}
.vip-feat-row:last-child { border-bottom: none; }
.vip-feat-icon { font-size: 40rpx; flex-shrink: 0; }
.vip-feat-text { flex: 1; }
.vip-feat-name { display: block; font-size: 28rpx; font-weight: 800; color: #f1f5f9; margin-bottom: 4rpx; }
.vip-feat-desc { display: block; font-size: 21rpx; color: rgba(255,255,255,.4); }
.vip-feat-tag {
  font-size: 19rpx; font-weight: 800; padding: 5rpx 16rpx; border-radius: 14rpx;
  flex-shrink: 0;
}
.vip-feat-tag.pro  { background: linear-gradient(135deg, rgba(251,191,36,.25), rgba(251,146,60,.2)); color: #fbbf24; border: 1rpx solid rgba(251,191,36,.4); }
.vip-feat-tag.soon { background: rgba(129,140,248,.18); color: #a5b4fc; border: 1rpx solid rgba(129,140,248,.3); }

/* 定价卡 */
.vip-price-row { display: flex; gap: 16rpx; margin-bottom: 32rpx; }
.vip-price-card {
  flex: 1; padding: 26rpx 0 22rpx; text-align: center;
  background: rgba(255,255,255,.05);
  border: 1.5rpx solid rgba(255,255,255,.1);
  border-radius: 28rpx; position: relative;
  transition: all .2s;
}
.vip-price-card.hot {
  background: linear-gradient(160deg, rgba(217,119,6,.18), rgba(251,191,36,.12));
  border-color: rgba(251,191,36,.5);
  box-shadow: 0 8rpx 30rpx rgba(251,191,36,.15);
  transform: scale(1.04);
}
.vip-hot-badge {
  position: absolute; top: -20rpx; left: 50%; transform: translateX(-50%);
  background: linear-gradient(135deg, #d97706, #fbbf24);
  color: #0d1117; font-size: 18rpx; font-weight: 900;
  padding: 5rpx 22rpx; border-radius: 20rpx;
  white-space: nowrap;
}
.vip-price-tag  { display: block; font-size: 22rpx; color: rgba(255,255,255,.45); margin-bottom: 8rpx; }
.vip-price-num  { display: block; font-size: 52rpx; font-weight: 900; color: #fbbf24; line-height: 1; }
.vip-price-unit { display: block; font-size: 20rpx; color: rgba(255,255,255,.35); margin-top: 4rpx; }
.vip-price-card.hot .vip-price-num { color: #fbbf24; }

/* CTA按钮 */
.vip-cta {
  background: linear-gradient(135deg, #d97706, #fbbf24, #fb923c);
  border-radius: 60rpx; padding: 26rpx 0; text-align: center;
  box-shadow: 0 8rpx 32rpx rgba(251,191,36,.4);
  margin-bottom: 24rpx;
}
.vip-cta text { font-size: 34rpx; font-weight: 900; color: #0d1117; letter-spacing: 2rpx; }

.vip-close {
  display: block; text-align: center;
  font-size: 26rpx; color: rgba(255,255,255,.28);
  padding: 10rpx 0;
}
