<!-- pages/index/index.wxml  v7.3 -->
<view class="page">

  <!-- ══ 免责声明弹窗（首次打开显示） ══ -->
  <view class="disclaimer-mask" wx:if="{{showDisclaimer}}">
    <view class="disclaimer-box">
      <view class="disclaimer-icon">⚠️</view>
      <text class="disclaimer-title">使用须知</text>
      <view class="disclaimer-content">
        <text class="disclaimer-txt">本工具仅供学习交流，展示K线技术指标数据。</text>
        <text class="disclaimer-txt">所有内容均不构成任何投资建议，不对任何交易结果负责。</text>
        <text class="disclaimer-txt">数字货币交易风险极高，请谨慎操作，量力而行。</text>
        <text class="disclaimer-txt">继续使用即视为您已知晓并同意以上说明。</text>
      </view>
      <view class="disclaimer-btn" bindtap="closeDisclaimer">
        <text>我已了解，进入使用 →</text>
      </view>
    </view>
  </view>

  <!-- ══ 顶部导航栏 ══ -->
  <view class="navbar">
    <view class="navbar-left">
      <view class="nav-radar-icon">
        <text class="nav-radar-emoji">📡</text>
        <view class="nav-radar-ring"></view>
      </view>
      <view class="nav-title-block">
        <text class="nav-title">大饼K线雷达</text>
        <text class="nav-sub">实时K线 · 多指标共振 · 智能预警</text>
      </view>
    </view>
    <view class="navbar-right">
      <view class="live-dot {{loading ? 'loading' : ''}}"></view>
      <view class="nav-vip-btn {{isVip ? 'vip-on' : ''}}" bindtap="showVipModal">
        <text class="nav-vip-icon">{{isVip ? '👑' : '🔒'}}</text>
        <text class="nav-vip-label">{{isVip ? 'Pro' : '升级'}}</text>
      </view>
      <view class="nav-refresh-btn" bindtap="refresh">
        <text class="nav-refresh-text">{{loading ? '⏳' : '🔄'}}</text>
        <text class="nav-refresh-label">{{loading ? '加载中' : '刷新'}}</text>
      </view>
    </view>
  </view>

  <!-- ══ 价格大头（全部左对齐，右边留白） ══ -->
  <view class="price-hero">
    <view class="price-hero-left">
      <text class="price-main {{priceDir}}">{{curPrice}}</text>
      <view class="price-badges">
        <text class="price-badge {{priceDir}}">{{priceChange}}</text>
        <text class="price-badge-plain">4h {{price4hChange}}</text>
        <text class="price-badge-plain">24h {{price24hChange}}</text>
        <text class="price-badge-plain">量 {{vol24h}}</text>
      </view>
    </view>
    <!-- 右侧空白区，未来可放趋势内容 -->
    <view class="price-hero-right-blank"></view>
  </view>



  <!-- ══ K线图区域（全部用户可见） ══ -->
  <view class="kline-section">

    <!-- 行1：周期切换栏（折叠下拉式） -->
    <view class="kline-title-row">
      <view class="kline-title-left">
        <text class="kline-section-icon">📈</text>
        <!-- 基础周期：直接显示 -->
        <view class="period-bar-inline">
          <view
            class="period-btn-sm {{interval === item.iv ? 'active' : ''}}"
            wx:for="{{basicPeriods}}" wx:key="iv" wx:for-item="item"
            bindtap="switchInterval"
            data-iv="{{item.iv}}"
            data-label="{{item.label}}"
          >{{item.label}}</view>
          <!-- 更多按钮 -->
          <view class="period-btn-sm more-btn {{periodMenuOpen ? 'active' : ''}}" bindtap="togglePeriodMenu">
            <text>{{periodMenuOpen ? '收起' : '更多▾'}}</text>
          </view>
        </view>
      </view>
      <view style="display:flex;align-items:center;gap:10rpx;flex-shrink:0;">
        <text class="kview-badge">{{klineView}}根/屏</text>
        <view class="chart-legend">
          <text class="leg-boll-u">BOLL↑</text>
          <text class="leg-boll-l">↓</text>
          <text class="leg-ma5">MA5</text>
          <text class="leg-ma10">MA10</text>
        </view>
      </view>
    </view>
    <!-- 展开的更多周期面板 -->
    <view class="period-more-panel" wx:if="{{periodMenuOpen}}">
      <view
        class="period-more-btn {{interval === item.iv ? 'active' : ''}}"
        wx:for="{{morePeriods}}" wx:key="iv" wx:for-item="item"
        bindtap="switchIntervalFromMenu"
        data-iv="{{item.iv}}"
        data-label="{{item.label}}"
      >{{item.label}}</view>
    </view>

    <!-- 行2：大趋势卡片（升级版） -->
    <view class="trend-card-v2 {{trendColor}}">
      <!-- 顶部：方向 + 趋势标签 -->
      <view class="trend-card-top">
        <view class="trend-card-title-row">
          <text class="trend-card-period">{{intervalLabel}} 大趋势</text>
          <view class="trend-card-badge {{trendColor}}">
            <text class="trend-badge-icon">{{trendColor === 'bull' ? '🚀' : trendColor === 'down' || trendColor === 'bear' ? '🐸' : trendColor === 'bull_weak' ? '🌤' : '🌧'}}</text>
            <text class="trend-badge-text">{{trendLabel}}</text>
          </view>
        </view>
        <text class="trend-card-desc">{{trendDesc}}</text>
      </view>
      <!-- 中部：MA20 / MA60 / 价格位置 -->
      <view class="trend-card-mid">
        <view class="trend-ma-item">
          <text class="trend-ma-label">MA20</text>
          <text class="trend-ma-val">{{trendMa20}}</text>
        </view>
        <view class="trend-ma-divider"></view>
        <view class="trend-ma-item">
          <text class="trend-ma-label">MA60</text>
          <text class="trend-ma-val">{{trendMa60}}</text>
        </view>
        <view class="trend-ma-divider"></view>
        <view class="trend-ma-item">
          <text class="trend-ma-label">支撑区</text>
          <text class="trend-ma-val green">{{supportZone}}</text>
        </view>
        <view class="trend-ma-divider"></view>
        <view class="trend-ma-item">
          <text class="trend-ma-label">压力区</text>
          <text class="trend-ma-val red">{{resistZone}}</text>
        </view>
      </view>
      <!-- 底部：趋势强度进度条 -->
      <view class="trend-card-bar-wrap">
        <view class="trend-card-bar-track">
          <view class="trend-card-bar-fill {{trendColor}}" style="width:{{trendStrength}}%"></view>
        </view>
        <text class="trend-card-bar-label">趋势强度 {{trendStrength}}%</text>
      </view>
    </view>
  </view>
  <view class="kcanvas-wrap"
    bindtouchmove="onKlineTouch"
    bindtouchend="onKlineTouchEnd"
    bindtouchstart="onKlineTouchStart"
  >
    <canvas type="2d" id="klineCanvas" class="kcanvas"></canvas>
    <!-- 操作提示 -->
    <view class="kcanvas-hint" wx:if="{{touchIdx < 0}}">
      <text>← 单指拖动  ·  双指缩放 →</text>
    </view>
    <!-- 触摸浮窗 -->
    <view class="ktooltip" wx:if="{{touchIdx >= 0}}" style="left:{{tooltipLeft}}px">
      <text class="ktt-time">{{touchTime}}</text>
      <view class="ktt-row"><text class="ktt-l">开</text><text class="ktt-v">{{touchO}}</text></view>
      <view class="ktt-row"><text class="ktt-l">高</text><text class="ktt-v up">{{touchH}}</text></view>
      <view class="ktt-row"><text class="ktt-l">低</text><text class="ktt-v dn">{{touchL}}</text></view>
      <view class="ktt-row"><text class="ktt-l">收</text><text class="ktt-v">{{touchC}}</text></view>
      <view class="ktt-row"><text class="ktt-l">量</text><text class="ktt-v">{{touchV}}</text></view>
      <view class="ktt-div"></view>
      <view class="ktt-row"><text class="ktt-l">MACD</text><text class="ktt-v">{{touchMACD}}</text></view>
      <view class="ktt-row"><text class="ktt-l">DIF</text><text class="ktt-v">{{touchDIF}}</text></view>
      <view class="ktt-row"><text class="ktt-l">DEA</text><text class="ktt-v">{{touchDEA}}</text></view>
    </view>
  </view>

  <!-- ══ 风控状态栏（全部用户可见） ══ -->
  <view class="risk-bar {{riskStatus}}">
    <view class="risk-left">
      <text class="risk-icon">{{riskStatus === 'normal' ? '✅' : riskStatus === 'cooldown' ? '🧊' : '🛑'}}</text>
      <text class="risk-txt">{{riskMsg}}</text>
    </view>
    <view class="risk-right" wx:if="{{riskStatus !== 'normal'}}">
      <text class="risk-time">{{cooldownUntil}}</text>
    </view>
  </view>

  <!-- ══ 非会员：轻量付费墙（K线以下内容锁住） ══ -->
  <block wx:if="{{!isVip}}">
    <view class="paywall-card">
      <!-- 模糊预览：让用户感觉数据就在下面 -->
      <view class="paywall-preview">
        <view class="preview-decision-card">
          <view class="preview-face-wrap">
            <text class="preview-face">🚀</text>
          </view>
          <view class="preview-info">
            <text class="preview-verdict">强势做多信号</text>
            <view class="preview-meta-row">
              <text class="preview-meta-tag">📈 做多</text>
              <text class="preview-meta-tag accent">胜率 74%</text>
              <text class="preview-meta-tag">盈亏比 1.8:1</text>
            </view>
          </view>
          <view class="preview-score-circle">
            <text class="preview-score-num">8</text>
            <text class="preview-score-den">/10</text>
          </view>
        </view>
        <view class="preview-tp-row">
          <view class="preview-tp-item stop"><text>止损</text><text class="preview-tp-val">██████</text></view>
          <view class="preview-tp-item tp1"><text>TP1</text><text class="preview-tp-val">██████</text></view>
          <view class="preview-tp-item tp2"><text>TP2</text><text class="preview-tp-val">██████</text></view>
          <view class="preview-tp-item tp3"><text>TP3</text><text class="preview-tp-val">██████</text></view>
        </view>
        <view class="paywall-blur-mask"></view>
      </view>

      <!-- 解锁文案 -->
      <view class="paywall-header">
        <text class="paywall-lock">🔐</text>
        <text class="paywall-title">解锁实时信号</text>
        <text class="paywall-sub">决策评分 · 精准止盈 · 多指标六维共振</text>
      </view>

      <!-- 价格 -->
      <view class="paywall-price-row">
        <view class="paywall-price-item">
          <text class="paywall-price-tag">月卡</text>
          <text class="paywall-price-num">¥88</text>
        </view>
        <view class="paywall-price-item hot">
          <text class="paywall-hot-badge">最划算</text>
          <text class="paywall-price-tag">季卡</text>
          <text class="paywall-price-num hot-num">¥168</text>
        </view>
        <view class="paywall-price-item">
          <text class="paywall-price-tag">年卡</text>
          <text class="paywall-price-num">¥498</text>
        </view>
        <view class="paywall-price-item">
          <text class="paywall-price-tag">永久</text>
          <text class="paywall-price-num">¥698</text>
        </view>
      </view>
      <view class="paywall-cta" bindtap="showVipModal">
        <text class="paywall-cta-text">👑 立即开通 · 查看实时信号 →</text>
      </view>
      <text class="paywall-hint">开通后即时解锁 · 联系作者激活</text>

      <!-- 激活码输入区 -->
      <view class="activate-wrap">
        <view class="activate-row">
          <input
            class="activate-input"
            placeholder="输入激活码"
            placeholder-class="activate-placeholder"
            value="{{activateCode}}"
            bindinput="onActivateInput"
            maxlength="20"
          />
          <view class="activate-btn {{activateCode ? 'active' : ''}}" bindtap="submitActivateCode">
            <text>激活</text>
          </view>
        </view>
        <text class="activate-err" wx:if="{{activateErr}}">{{activateErr}}</text>
      </view>
    </view>
  </block>

  <!-- ══ 会员解锁内容（isVip=true 才显示） ══ -->
  <block wx:if="{{isVip}}">

  <!-- ══ 多空能量对比 ══ -->
  <view class="energy-card">
    <view class="energy-header">
      <text class="energy-title">⚡ 多空能量对比</text>
      <text class="energy-dom {{energyDominance}}">{{domLabel}}</text>
    </view>
    <view class="energy-bar-wrap">
      <view class="energy-bull-bar" style="width:{{bullPct}}%">
        <text class="energy-bar-label">多 {{bullPct}}%</text>
      </view>
      <view class="energy-bear-bar" style="width:{{bearPct}}%">
        <text class="energy-bar-label">空 {{bearPct}}%</text>
      </view>
    </view>
  </view>


  <view class="decision-card {{decisionState}}">
    <!-- 背景光晕 -->
    <view class="decision-glow {{decisionState}}"></view>
    <view class="decision-top">
      <view class="decision-face-wrap {{decisionState}}">
        <text class="decision-face">{{decisionFace}}</text>
      </view>
      <view class="decision-text">
        <text class="decision-verdict">{{decisionVerdict}}</text>
        <text class="decision-sub">{{decisionSub}}</text>
        <view class="decision-meta" wx:if="{{hasSignal}}">
          <text class="meta-tag">{{signalDir === 'long' ? '📈 做多' : '📉 做空'}}</text>
          <text class="meta-tag accent">胜率 {{winRate}}%</text>
          <text class="meta-tag">盈亏比 {{rrRatio}}</text>
        </view>
      </view>
      <view class="score-circle {{decisionState}}">
        <text class="score-num">{{score}}</text>
        <text class="score-den">/10</text>
      </view>
    </view>
    <view class="score-bar-wrap">
      <view class="score-bar-fill {{decisionState}}" style="width:{{scoreBar}}%"></view>
    </view>
    <view class="decision-bottom">
      <text class="score-stars">{{scoreStars}}</text>
      <view class="score-label-wrap">
        <text class="score-label {{decisionState}}">{{scoreLabel}}</text>
        <text class="update-time">{{updateTime}} 更新</text>
      </view>
    </view>
  </view>

  <!-- ══ MACD金叉/死叉通知条 ══ -->
  <view class="macd-cross-bar {{macdCross.type === 'golden' ? 'golden' : 'dead'}}" wx:if="{{macdCrossShow}}">
    <text class="macd-cross-icon">{{macdCross.type === 'golden' ? '🟢' : '🔴'}}</text>
    <view class="macd-cross-info">
      <text class="macd-cross-title">MACD {{macdCross.type === 'golden' ? '金叉' : '死叉'}} · {{macdCross.strength}}叉</text>
      <text class="macd-cross-desc">{{macdCross.axisDesc}} | DIF:{{macdCross.dif}} DEA:{{macdCross.dea}}</text>
    </view>
    <text class="macd-cross-hint">{{macdCross.type === 'golden' ? '看多▲' : '看空▼'}}</text>
  </view>

  <!-- ══ 信号详情（有信号时） ══ -->
  <view class="signal-detail {{signalDir}}" wx:if="{{hasSignal}}">
    <view class="section-title">
      <text>🔔 信号详情</text>
      <text class="dir-tag {{signalDir}}">{{signalDir === 'long' ? '做多 ▲' : '做空 ▼'}}</text>
    </view>
    <view class="detail-grid">
      <view class="detail-cell">
        <text class="dc-label">📍 插针时间</text>
        <text class="dc-val">{{pinTime}}</text>
      </view>
      <view class="detail-cell">
        <text class="dc-label">🎯 胜率参考</text>
        <text class="dc-val accent">{{winRate}}%</text>
      </view>
    </view>

    <!-- 止盈止损完整版（做多/做空均显示） -->
    <view class="sl-tp-block">
      <view class="sl-tp-title">
        <text>{{signalDir === 'long' ? '🎯 做多 · 止盈止损参考' : '🎯 做空 · 止盈止损参考'}}</text>
      </view>
      <!-- 止损 -->
      <view class="sl-row">
        <view class="sl-tag stop">— 止损</view>
        <text class="sl-price stop">{{stopLoss}}</text>
        <text class="sl-hint">{{signalDir === 'long' ? '插针最低点下方' : '插针最高点上方'}}</text>
      </view>
      <!-- 入场 -->
      <view class="sl-row entry">
        <view class="sl-tag entry-tag">📍 入场价</view>
        <text class="sl-price">{{curPrice}}</text>
        <text class="sl-hint">当前价格入场</text>
      </view>
      <!-- TP1 -->
      <view class="sl-row tp">
        <view class="sl-tag tp1-tag {{signalDir}}">🎯 保守止盈</view>
        <text class="sl-price {{signalDir === 'long' ? 'tp-long' : 'tp-short'}}">{{tp1}}</text>
        <text class="sl-hint">1.0:1 盈亏比</text>
      </view>
      <!-- TP2 -->
      <view class="sl-row tp">
        <view class="sl-tag tp2-tag {{signalDir}}">🎯 标准止盈</view>
        <text class="sl-price {{signalDir === 'long' ? 'tp-long' : 'tp-short'}}">{{tp2}}</text>
        <text class="sl-hint">1.5:1 盈亏比</text>
      </view>
      <!-- TP3 -->
      <view class="sl-row tp">
        <view class="sl-tag tp3-tag {{signalDir}}">🎯 激进止盈</view>
        <text class="sl-price {{signalDir === 'long' ? 'tp-long-hi' : 'tp-short-hi'}}">{{tp3}}</text>
        <text class="sl-hint">2.5:1 盈亏比</text>
      </view>
    </view>

    <!-- 仓位建议 -->
    <view class="pos-row" wx:if="{{posLots > 0}}">
      <view class="pos-item">
        <text class="pos-label">📊 仓位建议</text>
        <text class="pos-val">{{posLots}}张</text>
      </view>
      <view class="pos-item">
        <text class="pos-label">保证金</text>
        <text class="pos-val">{{posMargin}}U</text>
      </view>
      <view class="pos-item">
        <text class="pos-label">仓位占比</text>
        <text class="pos-val">{{posRatio}}%</text>
      </view>
      <view class="pos-item">
        <text class="pos-label">杠杆</text>
        <text class="pos-val">{{posLeverage}}x</text>
      </view>
      <view class="pos-item">
        <text class="pos-label">最大亏损</text>
        <text class="pos-val">{{posRiskU}}U</text>
      </view>
    </view>
  </view>





  <!-- ══ 多空条件感知 ══ -->
  <view class="section-title-plain">
    <text>🧭 实时多空条件感知</text>
    <text class="section-sub">满足条件越多越强</text>
  </view>
  <view class="cond-wrap">
    <view class="cond-col">
      <view class="cond-col-title long-color">📈 做多条件</view>
      <view class="cond-item {{item.ok ? 'ok' : 'no'}}" wx:for="{{longConditions}}" wx:key="label" wx:item="item">
        <text class="cond-icon">{{item.ok ? '✅' : '⬜'}}</text>
        <view class="cond-text">
          <text class="cond-label">{{item.label}}</text>
          <text class="cond-tip">{{item.tip}}</text>
        </view>
      </view>
      <view class="cond-score-bar">
        <view class="cond-score-fill long" style="width:{{longScore}}%"></view>
        <text class="cond-score-txt">{{longOk}}/4</text>
      </view>
    </view>
    <view class="cond-divider"></view>
    <view class="cond-col">
      <view class="cond-col-title short-color">📉 做空条件</view>
      <view class="cond-item {{item.ok ? 'ok' : 'no'}}" wx:for="{{shortConditions}}" wx:key="label" wx:item="item">
        <text class="cond-icon">{{item.ok ? '✅' : '⬜'}}</text>
        <view class="cond-text">
          <text class="cond-label">{{item.label}}</text>
          <text class="cond-tip">{{item.tip}}</text>
        </view>
      </view>
      <view class="cond-score-bar">
        <view class="cond-score-fill short" style="width:{{shortScore}}%"></view>
        <text class="cond-score-txt">{{shortOk}}/4</text>
      </view>
    </view>
  </view>



  <!-- ══ 底部更新时间 ══ -->
  <view class="footer">
    <view class="footer-badge" bindtap="adminTap">🥞 大饼K线雷达  ·  60s自动嗅探</view>
    <text class="footer-txt">最后更新 {{updateTime}}</text>
    <text class="footer-txt">数据来源 🔥 火币HTX  /  🌐 币安镜像</text>
  </view>

  <!-- 管理员隐藏密码入口（连点3下触发） -->
  <view class="admin-pwd-float" wx:if="{{showAdminPwdBox}}">
    <view class="admin-pwd-inner">
      <input
        class="admin-pwd-input"
        type="number"
        password="{{true}}"
        placeholder="管理员密码"
        placeholder-class="admin-pwd-placeholder"
        value="{{adminPwdInput}}"
        bindinput="onAdminPwdInput"
        maxlength="8"
        focus="{{true}}"
      />
      <view class="admin-pwd-btn" bindtap="submitAdminPwd">进入</view>
      <view class="admin-pwd-close" bindtap="closeAdminPwd">✕</view>
    </view>
  </view>

  </block><!-- end isVip block -->

  <!-- ══ 会员升级弹窗 ══ -->
  <view class="vip-mask" wx:if="{{showVipModal}}" bindtap="closeVipModal">
    <view class="vip-box" catchtap="">
      <view class="vip-header">
        <text class="vip-crown">👑</text>
        <text class="vip-title">大饼K线雷达 Pro</text>
        <text class="vip-slogan">解锁全部专业功能</text>
      </view>
      <view class="vip-features">
        <view class="vip-feat-row">
          <text class="vip-feat-icon">🔔</text>
          <view class="vip-feat-text">
            <text class="vip-feat-name">实时推送提醒</text>
            <text class="vip-feat-desc">信号触发即刻推送到手机</text>
          </view>
          <text class="vip-feat-tag pro">Pro</text>
        </view>
        <view class="vip-feat-row">
          <text class="vip-feat-icon">📊</text>
          <view class="vip-feat-text">
