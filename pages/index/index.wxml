<!-- pages/index/index.wxml  v8.1  合规修复版 -->
<view class="page">

  <!-- ══ 首次免责声明弹窗（审核必备） ══ -->
  <view class="disclaimer-mask" wx:if="{{showDisclaimer}}">
    <view class="disclaimer-dialog">
      <view class="disc-header">
        <text class="disc-title">⚠️ 重要风险提示</text>
        <text class="disc-sub">请仔细阅读后再使用</text>
      </view>
      <scroll-view scroll-y class="disc-scroll">
        <text class="disc-body">本应用提供的BTC行情数据分析及交易信号，仅供学习和参考使用，不构成任何投资建议。

加密货币交易具有极高风险，价格波动剧烈，您可能损失全部投入资金。

本应用不对任何交易损失承担责任。所有交易决策均由用户自主做出，风险自行承担。

未满18周岁请勿使用。请遵守您所在地区的法律法规。</text>
      </scroll-view>
      <view class="disc-btn-row">
        <view class="disc-reject-btn" bindtap="rejectDisclaimer">
          <text>不同意，退出</text>
        </view>
        <view class="disc-agree-btn" bindtap="agreeDisclaimer">
          <text>我已阅读并同意</text>
        </view>
      </view>
    </view>
  </view>

  <!-- ══ 合并顶部栏：信号雷达 + AI标识 + 激活状态 ══ -->
  <view class="top-header">
    <view class="top-header-inner">
      <!-- 青蛙LOGO -->
      <view class="top-frog-wrap">
        <text class="top-frog-emoji">🐸</text>
      </view>
      <!-- 标题文字 -->
      <view class="top-title-block">
        <text class="top-title-main">BTC/USDT 信号雷达</text>
        <text class="top-title-sub">{{aiLabel}} · AI量化分析 · 插针精准识别</text>
      </view>
      <!-- 右侧：状态点 + 刷新 + 会员 -->
      <view class="top-right-area">
        <view class="live-dot {{loading ? 'loading' : ''}}"></view>
        <view class="nav-refresh-btn" bindtap="refresh">
          <text>{{loading ? '···' : '↻'}}</text>
        </view>
        <view class="top-vip-btn" bindtap="showVipDrawer">
          <text>{{isVip ? '👑' : '🔒'}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- ══ 价格大头（AI评分上方） ══ -->
  <view class="price-hero">
    <text class="price-main {{priceDir}}">{{curPrice}}</text>
    <view class="price-badges">
      <text class="price-badge {{priceDir}}">{{priceChange}}</text>
      <text class="price-badge-plain">4h {{price4hChange}}</text>
      <text class="price-badge-plain">24h {{price24hChange}}</text>
      <text class="price-badge-plain">量 {{vol24h}}</text>
    </view>
  </view>

  <!-- ══ AI评分 + 指标卡 合并大卡 ══ -->
  <view class="ai-ind-card">
    <!-- 顶部：圆圈 + 评分说明 + 入场建议 -->
    <view class="ai-ind-top">
      <view class="ai-score-ring-big {{decisionState}}">
        <text class="ai-ring-num-big">{{score}}</text>
        <text class="ai-ring-den-big">/100</text>
        <text class="ai-ring-label-big">AI评分</text>
      </view>
      <view class="ai-ind-right">
        <text class="ai-ind-verdict {{decisionState}}">{{scoreLabel}}</text>
        <text class="ai-ind-signal" wx:if="{{aiLabel}}">{{aiLabel}}</text>
        <view class="ai-score-bar-wrap">
          <view class="ai-score-bar-fill {{decisionState}}" style="width:{{scoreBar}}%"></view>
        </view>
        <!-- 入场分值门槛说明 -->
        <view class="ai-ind-threshold">
          <view class="ai-thr-item {{score >= 80 ? 'active-strong' : ''}}">
            <text class="ai-thr-dot strong"></text>
            <text class="ai-thr-txt">≥80 强烈推荐</text>
          </view>
          <view class="ai-thr-item {{score >= 60 && score < 80 ? 'active-ok' : ''}}">
            <text class="ai-thr-dot ok"></text>
            <text class="ai-thr-txt">60~79 建议入场</text>
          </view>
          <view class="ai-thr-item {{score < 60 ? 'active-wait' : ''}}">
            <text class="ai-thr-dot wait"></text>
            <text class="ai-thr-txt">&lt;60 观望等待</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 分割线 -->
    <view class="ai-ind-divider">
      <text class="ai-ind-divider-txt">📊 指标评分明细</text>
    </view>

    <!-- 指标卡片 2×4 网格 -->
    <view class="ind-grid">
      <view class="ind-card {{item.cls}}" wx:for="{{indCards}}" wx:key="name" wx:item="item">
        <!-- 分值角标 -->
        <view class="ind-score-badge {{item.score > 0 ? 'has-score' : ''}}" wx:if="{{item.maxScore > 0}}">
          <text class="ind-score-num">+{{item.score}}</text>
        </view>
        <view class="ind-top">
          <view class="ind-dot {{item.dot}}"></view>
          <text class="ind-name">{{item.name}}</text>
        </view>
        <text class="ind-val {{item.cls}}">{{item.val}}</text>
        <text class="ind-tip">{{item.tip}}</text>
        <view class="ind-prog-wrap">
          <view class="ind-prog-fill {{item.cls}}" style="width:{{item.progress}}%"></view>
        </view>
        <text class="ind-state {{item.dot}}">{{item.state}}</text>
      </view>
    </view>
  </view>

  <!-- ══ 2分钟倒计时条（非会员且在体验期时显示） ══ -->
  <view class="trial-bar" wx:if="{{!isVip && inTrial}}">
    <view class="trial-bar-fill" style="width:{{trialSecs / trialTotal * 100}}%"></view>
    <view class="trial-bar-content">
      <text class="trial-icon">⏳</text>
      <text class="trial-txt">免费体验剩余 <text class="trial-secs {{trialSecs <= 10 ? 'urgent' : ''}}">{{trialMin}}:{{trialSec < 10 ? '0' : ''}}{{trialSec}}</text></text>
      <text class="trial-cta" bindtap="showVipDrawer">开通会员 →</text>
    </view>
  </view>

  <!-- ══ 大趋势判断卡 ══ -->
  <view class="frog-trend-card">
    <view class="ftc-left">
      <view class="ftc-frog">{{trendIcon}}</view>
      <view class="ftc-info">
        <text class="ftc-title">大趋势判断</text>
        <text class="ftc-period">{{intervalLabel}} · MA20/MA60</text>
      </view>
    </view>
    <view class="ftc-right">
      <view class="ftc-badge {{trendColor}}">
        <text class="ftc-badge-txt">{{trendLabel}}</text>
      </view>
    </view>
  </view>

  <!-- ══ K线图区域（始终可见，在决策卡上方） ══ -->

  <!-- 【K线图Pill周期切换 + 标题行】 -->
  <view class="kline-header">
    <view class="kline-period-pills">
      <view
        class="kpill {{interval === item.iv ? 'kpill-active' : ''}}"
        wx:for="{{periods}}" wx:key="iv" wx:item="item"
        wx:if="{{item.base || showMorePeriods}}"
        bindtap="switchInterval"
        data-iv="{{item.iv}}"
        data-label="{{item.label}}"
      >{{item.iv}}</view>
      <view class="kpill kpill-more" bindtap="toggleMorePeriods">
        <text>{{showMorePeriods ? '↑' : '···'}}</text>
      </view>
    </view>
    <view class="kline-title-row">
      <text class="kline-title-txt">📈 K线 <text class="kview-badge">{{klineView}}根</text></text>
      <view class="chart-legend">
        <text class="leg-boll-u">BOLL↑</text>
        <text class="leg-boll-l">↓</text>
        <text class="leg-ma5">MA5</text>
        <text class="leg-ma10">MA10</text>
      </view>
    </view>
  </view>
  <view class="kcanvas-wrap"
    bindtouchmove="onKlineTouch"
    bindtouchstart="onKlineTouch"
    bindtouchend="onKlineTouchEnd"
    catchtouchmove="onKlineTouch"
  >
    <canvas type="2d" id="klineCanvas" class="kcanvas"></canvas>
    <view class="kcanvas-hint" wx:if="{{touchIdx < 0}}">
      <text>← 单指拖动  ·  双指缩放 →</text>
    </view>
    <view class="ktooltip" wx:if="{{touchIdx >= 0}}" style="left:{{tooltipLeft}}px">
      <text class="ktt-time">{{touchTime}}</text>
      <view class="ktt-row"><text class="ktt-l">开</text><text class="ktt-v">{{touchO}}</text></view>
      <view class="ktt-row"><text class="ktt-l">高</text><text class="ktt-v up">{{touchH}}</text></view>
      <view class="ktt-row"><text class="ktt-l">低</text><text class="ktt-v dn">{{touchL}}</text></view>
      <view class="ktt-row"><text class="ktt-l">收</text><text class="ktt-v">{{touchC}}</text></view>
      <view class="ktt-row"><text class="ktt-l">量</text><text class="ktt-v">{{touchV}}</text></view>
      <view class="ktt-div"></view>
      <view class="ktt-row"><text class="ktt-l">MACD</text><text class="ktt-v">{{touchMACD}}</text></view>
      <view class="ktt-row"><text class="ktt-l">DIF</text><text class="ktt-v">{{touchDIF}}</text></view>
      <view class="ktt-row"><text class="ktt-l">DEA</text><text class="ktt-v">{{touchDEA}}</text></view>
    </view>
  </view>

  <!-- ══ 决策大卡 ══ -->
  <view class="decision-card {{decisionState}}">
    <view class="decision-glow {{decisionState}}"></view>
    <!-- AI 角标 -->
    <view class="ai-corner-tag">
      <text>🤖 AI量化</text>
    </view>
    <view class="decision-top">
      <view class="decision-face-wrap {{decisionState}}">
        <text class="decision-face">{{decisionFace}}</text>
      </view>
      <view class="decision-text">
        <text class="decision-verdict">{{decisionVerdict}}</text>
        <text class="decision-sub">{{decisionSub}}</text>
        <view class="decision-meta" wx:if="{{hasSignal}}">
          <text class="meta-tag {{signalDir === 'long' ? 'long' : 'short'}}">{{signalDir === 'long' ? '📈 做多' : '📉 做空'}}</text>
          <text class="meta-tag">盈亏比 {{rrRatio}}</text>
        </view>
      </view>
    </view>
    <view class="score-bar-wrap">
      <view class="score-bar-fill {{decisionState}}" style="width:{{scoreBar}}%"></view>
    </view>
    <view class="decision-bottom">
      <text class="score-stars">{{scoreStars}}</text>
      <view class="score-label-wrap">
        <text class="score-label {{decisionState}}">{{scoreLabel}}</text>
        <text class="update-time">{{updateTime}} 更新</text>
      </view>
    </view>
  </view>


  <!-- ══ 以下内容：体验期OR会员显示；体验结束+非会员 → 付费墙 ══ -->
  <block wx:if="{{isVip || inTrial}}">

    <!-- 信号详情（有信号时，展示插针详情） -->
    <view class="signal-detail {{signalDir}}" wx:if="{{hasSignal}}">
      <view class="section-title">
        <text>🔔 信号详情</text>
        <text class="dir-tag {{signalDir}}">{{signalDir === 'long' ? '做多 ▲' : '做空 ▼'}}</text>
      </view>
      <view class="detail-grid">
        <view class="detail-cell">
          <text class="dc-label">📍 插针时间</text>
          <text class="dc-val">{{pinTime}}</text>
        </view>
        <view class="detail-cell">
          <text class="dc-label">🛑 止损位</text>
          <text class="dc-val loss">{{stopLoss}}</text>
        </view>
        <view class="detail-cell">
          <text class="dc-label">⚖️ 盈亏比</text>
          <text class="dc-val">{{rrRatio}}</text>
        </view>
      </view>
    </view>



    <!-- 多空条件感知 -->
    <view class="section-title-plain">
      <text>🧭 多空条件感知</text>
      <text class="section-sub">满足越多越强</text>
    </view>
    <view class="cond-wrap">
      <view class="cond-col">
        <view class="cond-col-title long-color">📈 做多条件</view>
        <view class="cond-item {{item.ok ? 'ok' : 'no'}}" wx:for="{{longConditions}}" wx:key="label" wx:item="item">
          <text class="cond-icon">{{item.ok ? '✅' : '⬜'}}</text>
          <view class="cond-text">
            <text class="cond-label">{{item.label}}</text>
            <text class="cond-tip">{{item.tip}}</text>
          </view>
        </view>
        <view class="cond-score-bar">
          <view class="cond-score-fill long" style="width:{{longScore}}%"></view>
          <text class="cond-score-txt">{{longOk}}/4</text>
        </view>
      </view>
      <view class="cond-divider"></view>
      <view class="cond-col">
        <view class="cond-col-title short-color">📉 做空条件</view>
        <view class="cond-item {{item.ok ? 'ok' : 'no'}}" wx:for="{{shortConditions}}" wx:key="label" wx:item="item">
          <text class="cond-icon">{{item.ok ? '✅' : '⬜'}}</text>
          <view class="cond-text">
            <text class="cond-label">{{item.label}}</text>
            <text class="cond-tip">{{item.tip}}</text>
          </view>
        </view>
        <view class="cond-score-bar">
          <view class="cond-score-fill short" style="width:{{shortScore}}%"></view>
          <text class="cond-score-txt">{{shortOk}}/4</text>
        </view>
      </view>
    </view>

  </block>

  <!-- ══ 付费墙（体验结束 + 非会员） ══ -->
  <block wx:else>
    <view class="paywall-full">
      <!-- 顶部AI大Logo -->
      <view class="pw-ai-header">
        <view class="pw-ai-circle">
          <text class="pw-ai-icon">🤖</text>
        </view>
        <text class="pw-ai-title">顶级AI算法 · 量化信号</text>
        <text class="pw-ai-sub">全球顶级算法 · 专业机构同款策略</text>
      </view>

      <!-- 免费体验已结束提示 -->
      <view class="pw-trial-end">
        <text class="pw-trial-end-icon">⏰</text>
        <text class="pw-trial-end-txt">60秒免费体验已结束</text>
        <text class="pw-trial-end-sub">开通会员继续获取AI信号，把握每一次行情机会</text>
      </view>

      <!-- 功能亮点 -->
      <view class="pw-features">
        <view class="pw-feat-item">
          <text class="pw-feat-icon">🎯</text>
          <view class="pw-feat-text">
            <text class="pw-feat-title">AI插针精准识别</text>
            <text class="pw-feat-desc">顶级AI量化模型，胜率72%+</text>
          </view>
        </view>
        <view class="pw-feat-item">
          <text class="pw-feat-icon">⚡</text>
          <view class="pw-feat-text">
            <text class="pw-feat-title">实时多空信号推送</text>
            <text class="pw-feat-desc">微信秒推 · 不错过任何机会</text>
          </view>
        </view>
        <view class="pw-feat-item">
          <text class="pw-feat-icon">📊</text>
          <view class="pw-feat-text">
            <text class="pw-feat-title">8项指标综合评分</text>
            <text class="pw-feat-desc">MACD·RSI·KDJ·BOLL联合分析</text>
          </view>
        </view>
        <view class="pw-feat-item">
          <text class="pw-feat-icon">🛡️</text>
          <view class="pw-feat-text">
            <text class="pw-feat-title">止盈止损自动计算</text>
            <text class="pw-feat-desc">盈亏比1.5:1 · TP1/TP2/TP3三档</text>
          </view>
        </view>
      </view>

      <!-- 用户见证 -->
      <view class="pw-testimonial">
        <text class="pw-test-quote">"用了3天，抓到两次插针，各赚了300U，真的牛！"</text>
        <text class="pw-test-author">— 会员 小王@上海</text>
      </view>

      <!-- 定价卡片 -->
      <view class="pw-pricing">
        <view class="pw-price-card month">
          <text class="pw-price-label">月卡</text>
          <view class="pw-price-amount"><text class="pw-price-sym">¥</text><text class="pw-price-num">88</text></view>
          <text class="pw-price-desc">30天无限使用</text>
        </view>
        <view class="pw-price-card year hot">
          <view class="pw-price-hot-tag">🔥 最划算</view>
          <text class="pw-price-label">年卡</text>
          <view class="pw-price-amount"><text class="pw-price-sym">¥</text><text class="pw-price-num">688</text></view>
          <text class="pw-price-desc">月均57元</text>
        </view>
        <view class="pw-price-card life">
          <text class="pw-price-label">永久</text>
          <view class="pw-price-amount"><text class="pw-price-sym">¥</text><text class="pw-price-num">888</text></view>
          <text class="pw-price-desc">买断终身</text>
        </view>
      </view>

      <!-- 主CTA按钮 -->
      <view class="pw-cta-btn" bindtap="onCtaContact">
        <text class="pw-cta-text">👑 立即开通 · 联系作者获取激活码</text>
      </view>
      <text class="pw-contact-hint">点击后复制微信号，加好友付款获取激活码</text>

      <!-- 激活码区域 -->
      <view class="pw-code-area">
        <text class="pw-code-title">已有激活码？</text>
        <view class="pw-code-row">
          <input class="pw-code-input" placeholder="输入激活码" bindinput="onCodeInput" value="{{codeInput}}" />
          <view class="pw-code-btn" bindtap="submitCode">
            <text>激活</text>
          </view>
        </view>
        <text class="pw-code-hint" bindtap="showPwdEntry">···</text>
      </view>

    </view>
  </block>


  <!-- ══ 底部 ══ -->
  <view class="footer" bindtap="onFooterTap">
    <text class="footer-logo">⚡ BTC AI Signal · 智能量化分析</text>
    <text class="footer-txt">最后更新 {{updateTime}}  ·  30秒自动刷新</text>
    <text class="footer-txt">数据来源：火币HTX / 币安镜像 · 仅供参考</text>
    <text class="footer-disclaimer">⚠️ 本工具仅供学习参考，不构成投资建议，投资有风险</text>
  </view>

  <!-- ══ 错误提示 ══ -->
  <view class="error-bar" wx:if="{{errorMsg}}">
    <text>⚠️ {{errorMsg}}</text>
    <text class="error-hint">开发模式请勾选「不校验合法域名」</text>
  </view>

  <!-- ══ 密码输入弹框 ══ -->
  <view class="pwd-mask" wx:if="{{showPwdDialog}}" bindtap="closePwdDialog">
    <view class="pwd-dialog" catchtap="">
      <text class="pwd-title">🔐 输入访问密码</text>
      <input class="pwd-input" type="number" password placeholder="请输入密码" bindinput="onPasswordInput" value="{{pwdInput}}" />
      <view class="pwd-submit" bindtap="submitPassword"><text>确认</text></view>
    </view>
  </view>

  <!-- ══ 会员升级抽屉 ══ -->
  <view class="vip-drawer-mask" wx:if="{{showVipDrawer}}" bindtap="hideVipDrawer">
    <view class="vip-drawer" catchtap="">
      <view class="vip-drawer-header">
        <text class="vip-drawer-title">👑 开通会员</text>
        <view class="vip-drawer-close" bindtap="hideVipDrawer"><text>✕</text></view>
      </view>

      <!-- 当前状态 -->
      <view class="vip-status-row">
        <text class="vip-status-icon">{{isVip ? '👑' : '🔒'}}</text>
        <text class="vip-status-txt">{{isVip ? '已是会员，尽情使用' : '当前未开通，开通后全功能使用'}}</text>
      </view>

      <!-- 定价 -->
      <view class="vip-price-row">
        <view class="vip-price-item month">
          <text class="vip-price-name">月卡</text>
          <view class="vip-price-num-wrap"><text class="vip-price-sym">¥</text><text class="vip-price-num">88</text></view>
          <text class="vip-price-desc">30天无限使用</text>
        </view>
        <view class="vip-price-item year hot">
          <view class="vip-price-hot">🔥 最划算</view>
          <text class="vip-price-name">年卡</text>
          <view class="vip-price-num-wrap"><text class="vip-price-sym">¥</text><text class="vip-price-num">688</text></view>
          <text class="vip-price-desc">月均57元</text>
        </view>
        <view class="vip-price-item life">
          <text class="vip-price-name">永久</text>
          <view class="vip-price-num-wrap"><text class="vip-price-sym">¥</text><text class="vip-price-num">888</text></view>
          <text class="vip-price-desc">买断终身</text>
        </view>
      </view>

      <!-- 联系开通 -->
      <view class="vip-cta-btn" bindtap="onCtaContact">
        <text class="vip-cta-txt">👑 联系作者获取激活码</text>
      </view>
      <text class="vip-cta-hint">点击复制微信号 · 加好友付款后获取激活码</text>

      <!-- 已有激活码 -->
      <view class="vip-code-area">
        <text class="vip-code-title">已有激活码？直接激活</text>
        <view class="vip-code-row">
          <input class="vip-code-input" placeholder="输入激活码" bindinput="onCodeInput" value="{{codeInput}}" />
          <view class="vip-code-btn" bindtap="submitCode"><text>激活</text></view>
        </view>
        <!-- 隐藏密码入口（内部使用） -->
        <text class="vip-pwd-hint" bindtap="showPwdEntry">···</text>
      </view>
    </view>
  </view>

</view>
